{
  "name": "minewiki-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/api",
    "apps/bot",
    "apps/web",
    "apps/worker",
    "packages/*"
  ],
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:worker": "pnpm --dir apps/worker dev",
    "dev:bot": "pnpm --dir apps/bot dev",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@minewiki/web",
    "build:api": "turbo run build --filter=@minewiki/api",
    "build:worker": "turbo run build --filter=@minewiki/worker",
    "build:bot": "turbo run build --filter=@minewiki/bot",
    "check": "turbo run check build --continue",
    "db:deploy": "node scripts/deploy-database.mjs",
    "env:prepare": "node scripts/prepare-production-env.mjs",
    "env:sync-voteweb-oauth": "node scripts/sync-voteweb-oauth.mjs",
    "env:sync-voteweb-auth-mail": "node scripts/sync-voteweb-oauth.mjs",
    "deploy:build": "pnpm install --frozen-lockfile && pnpm db:deploy && pnpm seed && pnpm build && pnpm data:backfill-wiki-search && pnpm deploy:web-release",
    "deploy:web-release": "node scripts/prepare-web-release.mjs",
    "deploy:smoke": "pnpm smoke",
    "data:validate": "node scripts/validate-data.mjs",
    "data:migrate-wiki": "node scripts/migrate-legacy-wiki.mjs",
    "data:backfill-wiki-links": "pnpm --filter @minewiki/wiki-core build && node scripts/backfill-wiki-links.mjs",
    "data:backfill-wiki-files": "pnpm --filter @minewiki/wiki-core build && node scripts/backfill-wiki-file-links.mjs",
    "data:backfill-wiki-search": "pnpm --filter @minewiki/wiki-core build && node scripts/backfill-wiki-search.mjs",
    "data:refresh-server-wiki-scaffolds": "pnpm --filter @minewiki/api build && node scripts/refresh-server-wiki-scaffolds.mjs",
    "backup": "node scripts/backup-minewiki.mjs",
    "backup:verify": "node scripts/verify-minewiki-backup.mjs",
    "backup:drill": "node scripts/drill-minewiki-backup.mjs",
    "pm2:validate": "node scripts/validate-pm2-config.mjs",
    "gateway:validate": "node scripts/validate-upload-gateway.mjs",
    "seed": "node scripts/seed.mjs",
    "typecheck": "turbo run build --continue",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:unit": "pnpm test:scripts && turbo run test --continue",
    "test:integration": "MINEWIKI_ALLOW_DB_TESTS=1 turbo run test --force --continue --filter=@minewiki/api --filter=@minewiki/bot",
    "lint": "turbo run lint --continue",
    "format": "pnpm lint -- --fix",
    "test": "pnpm test:scripts && turbo run test --continue",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "prisma": "^6.17.1",
    "turbo": "^1.13.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^16.6.1"
  },
  "pnpm": {
    "overrides": {
      "fast-uri@>=3.0.0 <3.1.4": "3.1.4",
      "fast-uri@>=4.0.0 <4.1.1": "4.1.1",
      "postcss@<8.5.10": "8.5.16",
      "sharp@<0.35.0": "0.35.3",
      "undici@<6.27.0": "6.27.0"
    }
  }
}
