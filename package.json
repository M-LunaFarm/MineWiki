{
  "name": "minewiki-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.15.9",
  "workspaces": [
    "apps/api",
    "apps/bot",
    "apps/web",
    "apps/worker",
    "packages/*"
  ],
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "dev:worker": "pnpm --dir apps/worker dev",
    "dev:bot": "pnpm --dir apps/bot dev",
    "build": "turbo run build",
    "build:web": "pnpm --dir apps/web build",
    "build:api": "pnpm --dir apps/api build",
    "build:worker": "pnpm --dir apps/worker build",
    "build:bot": "pnpm --dir apps/bot build",
    "check": "turbo run check build --continue",
    "db:deploy": "node scripts/deploy-database.mjs",
    "deploy:build": "pnpm db:deploy && pnpm seed && pnpm build",
    "deploy:smoke": "pnpm smoke",
    "data:validate": "node scripts/validate-data.mjs",
    "pm2:validate": "node scripts/validate-pm2-config.mjs",
    "gateway:validate": "node scripts/validate-upload-gateway.mjs",
    "seed": "node scripts/seed.mjs",
    "typecheck": "turbo run build --continue",
    "test:scripts": "node --test scripts/*.test.mjs",
    "test:unit": "pnpm test:scripts && turbo run test --continue",
    "test:integration": "turbo run test --force --continue --filter=@minewiki/api --filter=@minewiki/bot",
    "lint": "turbo run lint --continue",
    "format": "pnpm lint -- --fix",
    "test": "pnpm test:scripts && turbo run test --continue",
    "smoke": "node scripts/smoke-test.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "prisma": "^6.17.1",
    "turbo": "^1.13.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2",
    "dotenv": "^16.6.1"
  }
}
