{
  "name": "@minewiki/api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node -r module-alias/register dist/apps/api/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "tsx --test \"src/**/*.test.ts\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@minewiki/analytics": "workspace:*",
    "@minewiki/config": "workspace:*",
    "@minewiki/logger": "workspace:*",
    "@minewiki/schemas": "workspace:*",
    "@minewiki/security": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-fastify": "^10.3.0",
    "@nestjs/throttler": "^5.1.2",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^8.29.0",
    "bullmq": "^5.6.1",
    "cookie": "^0.6.0",
    "fastify": "^4.26.2",
    "file-type": "^18.7.0",
    "ioredis": "5.10.1",
    "minecraft-server-util": "^5.4.4",
    "module-alias": "^2.2.2",
    "nodemailer": "^6.9.14",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.0.1",
