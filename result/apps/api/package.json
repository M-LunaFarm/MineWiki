    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.2"
  },
  "_moduleAliases": {
    "@minewiki/analytics": "../../packages/analytics/dist",
    "@minewiki/config": "../../packages/config/dist",
    "@minewiki/logger": "../../packages/logger/dist",
    "@minewiki/security": "../../packages/security/dist",
    "@minewiki/schemas": "../../packages/schemas/dist"
