<%
  const guildName = currentGuild?.name || 'Guild';
  const guildId = currentGuild?.id || '';
  const guildIconUrl = currentGuild?.icon ? `https://cdn.discordapp.com/icons/${guildId}/${currentGuild.icon}.png?size=160` : '';
  const cancelQuery = selectedChannelId ? `?channel_id=${selectedChannelId}` : '';
  const botMessageFieldsSafe = (typeof botMessageFields !== 'undefined' && botMessageFields) ? botMessageFields : {};
  const verifyMessageFieldsSafe = (typeof verifyMessageFields !== 'undefined' && verifyMessageFields) ? verifyMessageFields : {};
  const navItems = [
    { key: 'overview', label: '개요', href: `/guilds/${guildId}${channelQuery}` },
    { key: 'settings', label: '설정', href: `/guilds/${guildId}/settings${channelQuery}` },
    ...(canManageSettings ? [
      { key: 'messages', label: '메시지', href: `/guilds/${guildId}/messages${channelQuery}` },
      { key: 'members', label: '멤버', href: `/guilds/${guildId}/members${channelQuery}` },
      { key: 'servers', label: '서버', href: `/guilds/${guildId}/servers${channelQuery}` },
      { key: 'actions', label: '액션', href: `/guilds/${guildId}/actions${channelQuery}` },
      { key: 'routing', label: '라우팅', href: `/guilds/${guildId}/routing${channelQuery}` }
    ] : []),
    { key: 'logs', label: '로그', href: `/guilds/${guildId}/logs${channelQuery}` }
  ];
  const logTemplates = [
    { fieldKey: 'default', prefix: 'log_default', label: '공통 메시지', helper: '이벤트별 설정이 비어있을 때 사용됩니다.', keyLabel: 'default', example: '{username} = {ign}' },
    { fieldKey: 'verification_completed', prefix: 'log_verification_completed', label: '인증 완료', helper: 'verification.completed', keyLabel: 'verification.completed' },
    { fieldKey: 'verification_revoked', prefix: 'log_verification_revoked', label: '인증 해제', helper: 'verification.revoked', keyLabel: 'verification.revoked' },
    { fieldKey: 'verification_reverified', prefix: 'log_verification_reverified', label: '재인증', helper: 'verification.reverified', keyLabel: 'verification.reverified' }
  ];
  const verifyTemplates = [
    { fieldKey: 'start', prefix: 'verify_start', label: '초기 응답', helper: 'verify.start', keyLabel: 'verify.start' },
    { fieldKey: 'error_forbidden', prefix: 'verify_error_forbidden', label: '권한 부족', helper: 'verify.error.forbidden', keyLabel: 'verify.error.forbidden' },
    { fieldKey: 'error_server', prefix: 'verify_error_server', label: '서버 오류', helper: 'verify.error.server', keyLabel: 'verify.error.server' },
    { fieldKey: 'error_unreachable', prefix: 'verify_error_unreachable', label: '서버 연결 실패', helper: 'verify.error.unreachable', keyLabel: 'verify.error.unreachable' },
    { fieldKey: 'error_default', prefix: 'verify_error_default', label: '기타 오류', helper: 'verify.error.default', keyLabel: 'verify.error.default' }
  ];
  const logTokens = ['{user}', '{username}', '{ign}', '{uuid}', '{discord_id}', '{guild_id}'];
  const verifyTokens = ['{user}', '{username}', '{discord_id}', '{guild_id}', '{verify_url}'];
%>
<%- include('../partials/top', { bodyClass: 'dashboard-page' }) %>

<style>
  .dashboard-page .page { max-width: 1280px; margin: 0 auto; width: 100%; }
  .bg-white\/85 { background: rgba(255,255,255,.85); }
  .bg-slate-50 { background: #f8fafc; }
  .bg-slate-100 { background: #f1f5f9; }
  .bg-slate-950 { background: #020617; }
  .bg-amber-50 { background: #fffbeb; }
  .bg-amber-600 { background: #d97706; }
  .bg-emerald-50 { background: #ecfdf5; }
  .bg-blue-50 { background: #eff6ff; }
  .border-slate-100 { border-color: #f1f5f9; }
  .border-slate-200 { border-color: #e2e8f0; }
  .border-slate-300 { border-color: #cbd5e1; }
  .border-amber-200 { border-color: #fde68a; }
  .border-emerald-200 { border-color: #a7f3d0; }
  .border-blue-200 { border-color: #bfdbfe; }
  .text-slate-950 { color: #020617; }
  .text-slate-900 { color: #0f172a; }
  .text-slate-800 { color: #1e293b; }
  .text-slate-700 { color: #334155; }
  .text-slate-600 { color: #475569; }
  .text-slate-500 { color: #64748b; }
  .text-amber-800 { color: #92400e; }
  .text-emerald-700 { color: #047857; }
  .text-blue-700 { color: #1d4ed8; }
  .shadow-sm { box-shadow: 0 1px 2px rgba(15,23,42,.08); }
  .shadow-xl { box-shadow: 0 20px 25px -5px rgba(15,23,42,.16), 0 8px 10px -6px rgba(15,23,42,.12); }
  .inset-x-4 { left: 1rem; right: 1rem; }
  .divide-slate-100 > :not([hidden]) ~ :not([hidden]) { border-color: #f1f5f9; }
  @media (hover:hover) {
    .hover\:bg-white:hover { background: #fff; }
    .hover\:bg-slate-50:hover { background: #f8fafc; }
    .hover\:bg-slate-100:hover { background: #f1f5f9; }
    .hover\:bg-slate-800:hover { background: #1e293b; }
    .hover\:bg-amber-700:hover { background: #b45309; }
    .hover\:text-slate-950:hover { color: #020617; }
  }
  @media (min-width: 640px) { .sm\:flex-none { flex: none; } }
  @media (min-width: 768px) {
    .md\:left-1\/2 { left: 50%; }
    .md\:right-auto { right: auto; }
    .md\:w-auto { width: auto; }
    .md\:-translate-x-1\/2 { transform: translateX(-50%); }
  }
  @media (min-width: 1024px) { .lg\:grid-cols-\[1fr_auto\] { grid-template-columns: 1fr auto; } }
</style>

<section class="mx-auto flex w-full max-w-7xl flex-col gap-6">
  <div class="flex flex-col gap-5 rounded-lg border border-slate-200 bg-white/85 p-5 shadow-sm lg:flex-row lg:items-center lg:justify-between">
    <div class="flex min-w-0 items-center gap-4">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
        <% if (guildIconUrl) { %>
          <img alt="Server Icon" class="h-full w-full object-cover" src="<%= guildIconUrl %>" />
        <% } else { %>
          <span class="text-lg font-semibold text-slate-500"><%= guildName.slice(0, 2) %></span>
        <% } %>
      </div>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="m-0 truncate font-['Space_Grotesk'] text-2xl font-semibold text-slate-950"><%= guildName %></h1>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">메시지</span>
        </div>
        <p class="mt-1 font-mono text-xs text-slate-500">ID: <%= guildId %></p>
      </div>
    </div>
    <button class="inline-flex items-center justify-center rounded-lg bg-slate-950 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" form="messagesForm" type="submit">
      저장
    </button>
  </div>

  <nav class="flex gap-2 overflow-x-auto border-b border-slate-200 pb-3">
    <% navItems.forEach((item) => { %>
      <a class="whitespace-nowrap rounded-lg px-3 py-2 text-sm font-medium <%= item.key === 'messages' ? 'bg-slate-950 text-white' : 'text-slate-600 hover:bg-white hover:text-slate-950' %>" href="<%= item.href %>"><%= item.label %></a>
    <% }) %>
  </nav>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <form class="grid gap-4 lg:grid-cols-[1fr_auto] lg:items-end" method="get" action="<%= actionPath %>">
      <div>
        <label class="block text-sm font-semibold text-slate-700" for="channel_id">설정 적용 범위</label>
        <select class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="channel_id" name="channel_id">
          <option value="">길드 기본값 (채널별 설정이 없을 때 적용)</option>
          <% channelOptions.forEach((channel) => { %>
            <option value="<%= channel.id %>" <%= selectedChannelId === channel.id ? 'selected' : '' %>>#<%= channel.name %> (이 채널만)</option>
          <% }) %>
        </select>
        <p class="mt-2 text-xs text-slate-500">길드 기본값은 채널별 설정이 없을 때 적용됩니다. 특정 채널을 선택하면 해당 채널에 저장됩니다.</p>
      </div>
      <button class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" type="submit">
        범위 적용
      </button>
    </form>
    <% if (!botPresent) { %>
      <div class="mt-4 flex flex-wrap items-center gap-3 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
        <span>봇이 길드에 초대되지 않아 채널 목록을 불러올 수 없습니다.</span>
        <% if (botInviteUrl) { %>
          <a class="inline-flex items-center justify-center rounded-lg bg-amber-600 px-3 py-2 text-xs font-semibold text-white hover:bg-amber-700" href="<%= botInviteUrl %>" target="_blank" rel="noopener noreferrer">
            봇 초대하기
          </a>
        <% } %>
      </div>
    <% } %>
  </section>

  <form id="messagesForm" method="post" action="/guilds/<%= guildId %>/messages">
    <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
    <input type="hidden" name="channel_id" value="<%= selectedChannelId %>" />

    <div class="grid grid-cols-1 gap-5 xl:grid-cols-2">
      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <h2 class="m-0 text-base font-semibold text-slate-950">봇 로그 메시지</h2>
            <p class="m-0 mt-1 text-sm text-slate-500">로그 채널로 전송되는 메시지입니다.</p>
          </div>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">Log Channel</span>
        </div>

        <div class="space-y-3">
          <% logTemplates.forEach((template) => { %>
            <% const fields = botMessageFieldsSafe[template.fieldKey] || {}; %>
            <details class="group rounded-lg border border-slate-200 bg-white">
              <summary class="flex cursor-pointer items-center justify-between gap-3 px-4 py-3">
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-slate-800"><%= template.label %></div>
                  <div class="truncate text-xs text-slate-500"><%= template.helper %></div>
                </div>
                <span class="shrink-0 rounded-md bg-slate-100 px-2 py-1 font-mono text-[11px] text-slate-600"><%= template.keyLabel %></span>
              </summary>
              <div class="space-y-4 border-t border-slate-100 px-4 py-4">
                <div>
                  <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_content">내용</label>
                  <textarea class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 font-mono text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_content" name="<%= template.prefix %>_content" rows="3" placeholder="메시지 내용을 입력하세요."><%= fields.content || '' %></textarea>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <% logTokens.forEach((token) => { %>
                      <button class="rounded-md border border-slate-200 bg-slate-50 px-2 py-1 font-mono text-xs text-slate-700 hover:bg-slate-100" type="button" data-target="<%= template.prefix %>_content" data-insert="<%= token %>"><%= token %></button>
                    <% }) %>
                  </div>
                  <% if (template.example) { %>
                    <p class="mt-2 text-xs text-slate-500">예: <%= template.example %></p>
                  <% } %>
                </div>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_embed_title">임베드 제목</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_embed_title" name="<%= template.prefix %>_embed_title" type="text" value="<%= fields.embed_title || '' %>" placeholder="임베드 제목" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_embed_color">임베드 컬러</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 font-mono text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_embed_color" name="<%= template.prefix %>_embed_color" type="text" value="<%= fields.embed_color || '' %>" placeholder="#5865F2" />
                  </div>
                  <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_embed_description">임베드 설명</label>
                    <textarea class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_embed_description" name="<%= template.prefix %>_embed_description" rows="2" placeholder="임베드 설명"><%= fields.embed_description || '' %></textarea>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_button_label">버튼 라벨</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_button_label" name="<%= template.prefix %>_button_label" type="text" value="<%= fields.button_label || '' %>" placeholder="예: 인증 링크" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_button_url">버튼 링크</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_button_url" name="<%= template.prefix %>_button_url" type="text" value="<%= fields.button_url || '' %>" placeholder="https://verify.minewiki.kr/..." />
                  </div>
                </div>
              </div>
            </details>
          <% }) %>
        </div>

        <div class="mt-6 border-t border-slate-200 pt-5">
          <div class="mb-3 flex items-start justify-between gap-4">
            <div>
              <h3 class="m-0 text-sm font-semibold text-slate-950">유저 DM 메시지</h3>
              <p class="m-0 mt-1 text-xs text-slate-500">인증 완료 시 유저에게 전송됩니다.</p>
            </div>
            <span class="rounded-full border border-emerald-200 bg-emerald-50 px-2.5 py-1 text-xs font-medium text-emerald-700">Direct Message</span>
          </div>
          <% const dmFields = botMessageFieldsSafe.dm_verification_completed || {}; %>
          <details class="group rounded-lg border border-slate-200 bg-white">
            <summary class="flex cursor-pointer items-center justify-between gap-3 px-4 py-3">
              <div class="min-w-0">
                <div class="text-sm font-semibold text-slate-800">인증 완료 DM</div>
                <div class="truncate text-xs text-slate-500">dm.verification.completed</div>
              </div>
              <span class="shrink-0 rounded-md bg-slate-100 px-2 py-1 font-mono text-[11px] text-slate-600">dm.verification.completed</span>
            </summary>
            <div class="space-y-4 border-t border-slate-100 px-4 py-4">
              <div>
                <label class="block text-sm font-semibold text-slate-700" for="dm_verification_completed_content">내용</label>
                <textarea class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 font-mono text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="dm_verification_completed_content" name="dm_verification_completed_content" rows="3" placeholder="DM 내용을 입력하세요."><%= dmFields.content || '' %></textarea>
                <div class="mt-2 flex flex-wrap gap-2">
                  <% logTokens.forEach((token) => { %>
                    <button class="rounded-md border border-slate-200 bg-slate-50 px-2 py-1 font-mono text-xs text-slate-700 hover:bg-slate-100" type="button" data-target="dm_verification_completed_content" data-insert="<%= token %>"><%= token %></button>
                  <% }) %>
                </div>
              </div>
              <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                <div>
                  <label class="block text-sm font-semibold text-slate-700" for="dm_verification_completed_embed_title">임베드 제목</label>
                  <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="dm_verification_completed_embed_title" name="dm_verification_completed_embed_title" type="text" value="<%= dmFields.embed_title || '' %>" placeholder="임베드 제목" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-slate-700" for="dm_verification_completed_embed_color">임베드 컬러</label>
                  <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 font-mono text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="dm_verification_completed_embed_color" name="dm_verification_completed_embed_color" type="text" value="<%= dmFields.embed_color || '' %>" placeholder="#10B981" />
                </div>
                <div class="md:col-span-2">
                  <label class="block text-sm font-semibold text-slate-700" for="dm_verification_completed_embed_description">임베드 설명</label>
                  <textarea class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="dm_verification_completed_embed_description" name="dm_verification_completed_embed_description" rows="2" placeholder="임베드 설명"><%= dmFields.embed_description || '' %></textarea>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-slate-700" for="dm_verification_completed_button_label">버튼 라벨</label>
                  <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="dm_verification_completed_button_label" name="dm_verification_completed_button_label" type="text" value="<%= dmFields.button_label || '' %>" placeholder="예: 서버 규칙" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-slate-700" for="dm_verification_completed_button_url">버튼 링크</label>
                  <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="dm_verification_completed_button_url" name="dm_verification_completed_button_url" type="text" value="<%= dmFields.button_url || '' %>" placeholder="https://..." />
                </div>
              </div>
            </div>
          </details>
        </div>
      </section>

      <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
        <div class="mb-5 flex items-start justify-between gap-4">
          <div>
            <h2 class="m-0 text-base font-semibold text-slate-950">/verify 응답 메시지</h2>
            <p class="m-0 mt-1 text-sm text-slate-500">슬래시 명령어 응답입니다.</p>
          </div>
          <span class="rounded-full border border-blue-200 bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">Verify Reply</span>
        </div>

        <div class="space-y-3">
          <% verifyTemplates.forEach((template) => { %>
            <% const fields = verifyMessageFieldsSafe[template.fieldKey] || {}; %>
            <details class="group rounded-lg border border-slate-200 bg-white">
              <summary class="flex cursor-pointer items-center justify-between gap-3 px-4 py-3">
                <div class="min-w-0">
                  <div class="text-sm font-semibold text-slate-800"><%= template.label %></div>
                  <div class="truncate text-xs text-slate-500"><%= template.helper %></div>
                </div>
                <span class="shrink-0 rounded-md bg-slate-100 px-2 py-1 font-mono text-[11px] text-slate-600"><%= template.keyLabel %></span>
              </summary>
              <div class="space-y-4 border-t border-slate-100 px-4 py-4">
                <div>
                  <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_content">내용</label>
                  <textarea class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 font-mono text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_content" name="<%= template.prefix %>_content" rows="3" placeholder="메시지 내용을 입력하세요."><%= fields.content || '' %></textarea>
                  <div class="mt-2 flex flex-wrap gap-2">
                    <% verifyTokens.forEach((token) => { %>
                      <button class="rounded-md border border-slate-200 bg-slate-50 px-2 py-1 font-mono text-xs text-slate-700 hover:bg-slate-100" type="button" data-target="<%= template.prefix %>_content" data-insert="<%= token %>"><%= token %></button>
                    <% }) %>
                  </div>
                </div>
                <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_embed_title">임베드 제목</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_embed_title" name="<%= template.prefix %>_embed_title" type="text" value="<%= fields.embed_title || '' %>" placeholder="임베드 제목" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_embed_color">임베드 컬러</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 font-mono text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_embed_color" name="<%= template.prefix %>_embed_color" type="text" value="<%= fields.embed_color || '' %>" placeholder="#5865F2" />
                  </div>
                  <div class="md:col-span-2">
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_embed_description">임베드 설명</label>
                    <textarea class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_embed_description" name="<%= template.prefix %>_embed_description" rows="2" placeholder="임베드 설명"><%= fields.embed_description || '' %></textarea>
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_button_label">버튼 라벨</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_button_label" name="<%= template.prefix %>_button_label" type="text" value="<%= fields.button_label || '' %>" placeholder="예: 인증 링크" />
                  </div>
                  <div>
                    <label class="block text-sm font-semibold text-slate-700" for="<%= template.prefix %>_button_url">버튼 링크</label>
                    <input class="mt-2 w-full rounded-lg border border-slate-300 bg-white px-3 py-2.5 text-sm text-slate-900 shadow-sm focus:border-teal-500 focus:outline-none focus:ring-2 focus:ring-teal-100" id="<%= template.prefix %>_button_url" name="<%= template.prefix %>_button_url" type="text" value="<%= fields.button_url || '' %>" placeholder="https://verify.minewiki.kr/..." />
                  </div>
                </div>
              </div>
            </details>
          <% }) %>
        </div>
      </section>
    </div>

    <div class="fixed inset-x-4 bottom-4 z-20 hidden rounded-lg border border-slate-200 bg-white p-3 shadow-xl md:left-1/2 md:right-auto md:w-auto md:-translate-x-1/2" id="messagesActionBar">
      <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
        <span class="text-sm font-medium text-slate-700">설정이 변경되었습니다.</span>
        <div class="flex items-center gap-2">
          <button class="inline-flex flex-1 items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50 sm:flex-none" type="button" data-action="reset">취소</button>
          <button class="inline-flex flex-1 items-center justify-center rounded-lg bg-slate-950 px-4 py-2 text-sm font-semibold text-white hover:bg-slate-800 sm:flex-none" type="submit" data-action="submit">저장</button>
        </div>
      </div>
    </div>
  </form>
</section>

<script>
  (() => {
    const form = document.getElementById('messagesForm');
    const actionBar = document.getElementById('messagesActionBar');
    if (!form || !actionBar) return;

    const snapshot = () => {
      const entries = Array.from(new FormData(form).entries());
      entries.sort((a, b) => {
        const keyCompare = a[0].localeCompare(b[0]);
        return keyCompare !== 0 ? keyCompare : String(a[1]).localeCompare(String(b[1]));
      });
      return entries.map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(value)}`).join('&');
    };

    const baseline = snapshot();
    const updateState = () => {
      actionBar.classList.toggle('hidden', snapshot() === baseline);
    };

    const resetButton = actionBar.querySelector('[data-action="reset"]');
    if (resetButton) {
      resetButton.addEventListener('click', () => {
        form.reset();
        updateState();
      });
    }

    form.addEventListener('input', updateState);
    form.addEventListener('change', updateState);

    let lastFocusedId = null;
    form.addEventListener('focusin', (event) => {
      const target = event.target;
      if (target && target.id) {
        lastFocusedId = target.id;
      }
    });

    document.querySelectorAll('[data-insert]').forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target') || lastFocusedId;
        const token = button.getAttribute('data-insert') || '';
        const input = document.getElementById(targetId);
        if (!input) return;
        const start = input.selectionStart ?? input.value.length;
        const end = input.selectionEnd ?? input.value.length;
        input.value = `${input.value.slice(0, start)}${token}${input.value.slice(end)}`;
        const caret = start + token.length;
        input.focus();
        if (input.setSelectionRange) {
          input.setSelectionRange(caret, caret);
        }
        input.dispatchEvent(new Event('input', { bubbles: true }));
      });
    });
  })();
</script>

