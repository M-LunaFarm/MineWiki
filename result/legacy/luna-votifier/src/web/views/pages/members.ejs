<%
  const guildName = currentGuild?.name || 'Guild';
  const guildId = currentGuild?.id || '';
  const guildIconUrl = currentGuild?.icon ? `https://cdn.discordapp.com/icons/${guildId}/${currentGuild.icon}.png?size=160` : '';
  const safeSelectedChannelId = typeof selectedChannelId !== 'undefined' ? selectedChannelId : '';
  const searchValue = searchQuery || '';
  const verifiedTotalPages = Math.max(1, Math.ceil(verifiedTotal / verifiedPerPage));
  const verifiedPrevPage = verifiedPage > 1 ? verifiedPage - 1 : 1;
  const verifiedNextPage = verifiedPage < verifiedTotalPages ? verifiedPage + 1 : verifiedTotalPages;
  const queryString = (params = {}) => {
    const query = new URLSearchParams();
    if (safeSelectedChannelId) query.set('channel_id', safeSelectedChannelId);
    Object.entries(params).forEach(([key, value]) => {
      if (value !== undefined && value !== null && value !== '') {
        query.set(key, String(value));
      }
    });
    const value = query.toString();
    return value ? `?${value}` : '';
  };
  const channelQuery = queryString();
  const verifiedPageSuffix = queryString({ verified_page: verifiedPage });
  const navItems = [
    { key: 'overview', label: '개요', href: `/guilds/${guildId}${channelQuery}` },
    { key: 'settings', label: '설정', href: `/guilds/${guildId}/settings${channelQuery}` },
    ...(canManageSettings ? [
      { key: 'messages', label: '메시지', href: `/guilds/${guildId}/messages${channelQuery}` },
      { key: 'members', label: '멤버', href: `/guilds/${guildId}/members${channelQuery}` },
      { key: 'servers', label: '서버', href: `/guilds/${guildId}/servers${channelQuery}` },
      { key: 'actions', label: '액션', href: `/guilds/${guildId}/actions${channelQuery}` },
      { key: 'routing', label: '라우팅', href: `/guilds/${guildId}/routing${channelQuery}` }
    ] : []),
    { key: 'logs', label: '로그', href: `/guilds/${guildId}/logs${channelQuery}` }
  ];
%>
<%- include('../partials/top', { bodyClass: 'dashboard-page' }) %>

<section class="mx-auto flex w-full max-w-7xl flex-col gap-6">
  <div class="flex flex-col gap-5 rounded-lg border border-slate-200 bg-white/85 p-5 shadow-sm lg:flex-row lg:items-center lg:justify-between">
    <div class="flex min-w-0 items-center gap-4">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
        <% if (guildIconUrl) { %>
          <img alt="Server Icon" class="h-full w-full object-cover" src="<%= guildIconUrl %>" />
        <% } else { %>
          <span class="text-lg font-semibold text-slate-500"><%= guildName.slice(0, 2) %></span>
        <% } %>
      </div>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="m-0 truncate font-['Space_Grotesk'] text-2xl font-semibold text-slate-950"><%= guildName %></h1>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">멤버</span>
        </div>
        <p class="mt-1 font-mono text-xs text-slate-500">ID: <%= guildId %></p>
      </div>
    </div>
  </div>

  <nav class="flex gap-2 overflow-x-auto border-b border-slate-200 pb-3" aria-label="길드 관리 메뉴">
    <% navItems.forEach((item) => { %>
      <a class="whitespace-nowrap rounded-lg px-3 py-2 text-sm font-medium <%= item.key === 'members' ? 'bg-slate-950 text-white' : 'text-slate-600 hover:bg-white hover:text-slate-950' %>" href="<%= item.href %>"><%= item.label %></a>
    <% }) %>
  </nav>

  <div class="stats">
    <div class="stat-card">
      <p class="stat-label">표시된 멤버</p>
      <strong><%= members.length %></strong>
    </div>
    <div class="stat-card">
      <p class="stat-label">관리 권한</p>
      <strong><%= permissionRows ? permissionRows.length : 0 %></strong>
    </div>
    <div class="stat-card">
      <p class="stat-label">인증됨</p>
      <strong><%= verifiedTotal %></strong>
    </div>
  </div>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="section-header">
      <div>
        <h2>권한 관리</h2>
        <p class="channel-hint">설정을 변경할 수 있는 Discord 유저입니다.</p>
      </div>
      <span class="badge badge-off">소유자 전용</span>
    </div>

    <% if (isGuildOwner) { %>
      <form class="form channel-form" method="post" action="/guilds/<%= guildId %>/members/permissions">
        <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
        <input type="hidden" name="action" value="grant" />
        <input type="hidden" name="members_after" value="<%= membersAfter %>" />
        <input type="hidden" name="verified_page" value="<%= verifiedPage %>" />
        <input type="hidden" name="search" value="<%= searchValue %>" />
        <input type="hidden" name="channel_id" value="<%= safeSelectedChannelId %>" />
        <label>
          Discord 유저 ID
          <input name="member_id" type="text" inputmode="numeric" placeholder="1234567890..." required />
        </label>
        <button class="btn btn-primary" type="submit">권한 부여</button>
      </form>
    <% } else { %>
      <p class="channel-hint">Owner만 권한을 관리할 수 있습니다.</p>
    <% } %>

    <div class="member-list">
      <% if (!permissionRows || permissionRows.length === 0) { %>
        <p class="empty-state">권한이 부여된 멤버가 없습니다.</p>
      <% } %>
      <% (permissionRows || []).forEach((row) => { %>
        <% const profile = permissionProfileMap ? permissionProfileMap[row.discord_user_id] : null; %>
        <% const initial = (profile?.display_name || profile?.username || row.discord_user_id || '?').slice(0, 2); %>
        <article class="member-item">
          <div class="member-main">
            <div class="member-avatar" data-initial="<%= initial %>">
              <% if (profile?.avatar) { %>
                <img alt="" src="<%= profile.avatar %>" loading="lazy" decoding="async" onerror="this.style.display='none';this.parentElement.dataset.fallback='1';" />
              <% } %>
            </div>
            <div class="member-copy">
              <strong><%= profile?.display_name || profile?.username || '이름 없음' %></strong>
              <p class="mono"><%= profile?.tag || row.discord_user_id %></p>
              <p class="mono select-all"><%= row.discord_user_id %></p>
            </div>
          </div>
          <div class="member-actions">
            <span class="badge badge-live">관리</span>
            <% if (isGuildOwner) { %>
              <form method="post" action="/guilds/<%= guildId %>/members/permissions">
                <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
                <input type="hidden" name="action" value="revoke" />
                <input type="hidden" name="member_id" value="<%= row.discord_user_id %>" />
                <input type="hidden" name="members_after" value="<%= membersAfter %>" />
                <input type="hidden" name="verified_page" value="<%= verifiedPage %>" />
                <input type="hidden" name="search" value="<%= searchValue %>" />
                <input type="hidden" name="channel_id" value="<%= safeSelectedChannelId %>" />
                <button class="btn btn-danger" type="submit">권한 해제</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="section-header">
      <div>
        <h2>Discord 멤버</h2>
        <p class="channel-hint">검색한 멤버에게 관리 권한을 부여하거나 해제합니다.</p>
      </div>
    </div>

    <form class="form channel-form" method="get" action="/guilds/<%= guildId %>/members">
      <input type="hidden" name="verified_page" value="<%= verifiedPage %>" />
      <input type="hidden" name="channel_id" value="<%= safeSelectedChannelId %>" />
      <label>
        검색
        <input name="search" type="text" placeholder="닉네임 또는 Discord ID" value="<%= searchValue %>" />
      </label>
      <button class="btn btn-primary" type="submit">검색</button>
      <% if (searchValue) { %>
        <a class="btn btn-ghost" href="/guilds/<%= guildId %>/members<%= verifiedPageSuffix %>">검색 해제</a>
      <% } %>
    </form>

    <% if (!botPresent) { %>
      <p class="empty-state">봇이 서버에 없습니다. 멤버 목록을 보려면 봇을 초대해 주세요.</p>
      <% if (botInviteUrl) { %><a class="btn btn-primary" href="<%= botInviteUrl %>" target="_blank" rel="noopener noreferrer">봇 초대</a><% } %>
    <% } else { %>
      <div class="member-list">
        <% if (members.length === 0) { %><p class="empty-state">표시할 멤버가 없습니다.</p><% } %>
        <% members.forEach((member) => { %>
          <% const hasPermission = permissionMap && permissionMap[member.id]; %>
          <% const initial = (member.display_name || member.username || member.id || '?').slice(0, 2); %>
          <article class="member-item">
            <div class="member-main">
              <div class="member-avatar" data-initial="<%= initial %>">
                <img alt="" src="<%= member.avatar %>" loading="lazy" decoding="async" onerror="this.style.display='none';this.parentElement.dataset.fallback='1';" />
              </div>
              <div class="member-copy">
                <strong><%= member.display_name %></strong>
                <p class="mono"><%= member.tag %></p>
                <p class="mono select-all"><%= member.id %></p>
              </div>
            </div>
            <div class="member-actions">
              <span class="badge <%= hasPermission ? 'badge-live' : 'badge-off' %>"><%= hasPermission ? '권한 있음' : '권한 없음' %></span>
              <% if (isGuildOwner) { %>
                <form method="post" action="/guilds/<%= guildId %>/members/permissions">
                  <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
                  <input type="hidden" name="member_id" value="<%= member.id %>" />
                  <input type="hidden" name="action" value="<%= hasPermission ? 'revoke' : 'grant' %>" />
                  <input type="hidden" name="members_after" value="<%= membersAfter %>" />
                  <input type="hidden" name="verified_page" value="<%= verifiedPage %>" />
                  <input type="hidden" name="search" value="<%= searchValue %>" />
                  <input type="hidden" name="channel_id" value="<%= safeSelectedChannelId %>" />
                  <button class="btn <%= hasPermission ? 'btn-danger' : 'btn-ghost' %>" type="submit"><%= hasPermission ? '권한 해제' : '권한 부여' %></button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
      <div class="pagination-row">
        <p class="channel-hint">표시: <%= members.length %>명<%= searchValue ? ' (검색)' : '' %></p>
        <div class="action-stack">
          <% if (!searchValue && membersAfter) { %><a class="btn btn-ghost" href="/guilds/<%= guildId %>/members<%= verifiedPageSuffix %>">처음</a><% } %>
          <% if (!searchValue && nextMembersAfter) { %><a class="btn btn-ghost" href="/guilds/<%= guildId %>/members<%= queryString({ members_after: nextMembersAfter, verified_page: verifiedPage }) %>">다음</a><% } %>
        </div>
      </div>
    <% } %>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="section-header">
      <div>
        <h2>인증된 목록</h2>
        <p class="channel-hint">현재 인증된 Minecraft 계정입니다.</p>
      </div>
      <span class="badge badge-off">총 <%= verifiedTotal %>명</span>
    </div>

    <div class="member-list">
      <% if (verifiedLinks.length === 0) { %>
        <p class="empty-state">인증된 유저가 없습니다.</p>
      <% } %>
      <% verifiedLinks.forEach((row) => { %>
        <% const initial = (row.mc_ign || row.discord_user_id || '?').slice(0, 2); %>
        <article class="member-item">
          <div class="member-main">
            <div class="member-avatar minecraft" data-initial="<%= initial %>">
              <span><%= initial %></span>
            </div>
            <div class="member-copy">
              <strong><%= row.mc_ign || '이름 없음' %></strong>
              <p class="mono">Discord ID: <span class="select-all"><%= row.discord_user_id %></span></p>
              <p class="mono select-all"><%= row.mc_uuid %></p>
              <p class="channel-hint"><%= row.verified_at_display %></p>
            </div>
          </div>
          <div class="member-actions">
            <span class="badge badge-live">인증됨</span>
            <% if (canManageSettings) { %>
              <form method="post" action="/guilds/<%= guildId %>/members/revoke" onsubmit="return confirm('이 유저의 인증을 해제할까요?');">
                <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
                <input type="hidden" name="discord_user_id" value="<%= row.discord_user_id %>" />
                <input type="hidden" name="members_after" value="<%= membersAfter %>" />
                <input type="hidden" name="verified_page" value="<%= verifiedPage %>" />
                <input type="hidden" name="search" value="<%= searchValue %>" />
                <input type="hidden" name="channel_id" value="<%= safeSelectedChannelId %>" />
                <button class="btn btn-danger" type="submit">인증 해제</button>
              </form>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>

    <div class="pagination-row">
      <p class="channel-hint">페이지 <%= verifiedPage %> / <%= verifiedTotalPages %></p>
      <div class="action-stack">
        <% if (verifiedPage > 1) { %><a class="btn btn-ghost" href="/guilds/<%= guildId %>/members<%= queryString({ members_after: membersAfter, search: searchValue, verified_page: verifiedPrevPage }) %>">이전</a><% } %>
        <% if (verifiedPage < verifiedTotalPages) { %><a class="btn btn-ghost" href="/guilds/<%= guildId %>/members<%= queryString({ members_after: membersAfter, search: searchValue, verified_page: verifiedNextPage }) %>">다음</a><% } %>
      </div>
    </div>
  </section>
</section>

<%- include('../partials/bottom') %>
