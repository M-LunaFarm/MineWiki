<%
  const guildId = currentGuild?.id || '';
  const guildName = currentGuild?.name || 'Guild';
  const safeChannelQuery = typeof channelQuery !== 'undefined' ? channelQuery : '';
  const backUrl = `/guilds/${guildId}/servers`;
  const serverTarget = server.server_host && server.server_port ? `${server.server_host}:${server.server_port}` : '';
%>
<%- include('../partials/top', { bodyClass: 'dashboard' }) %>

<div class="section-header">
  <div>
    <h1>서버 시크릿</h1>
    <p class="channel-hint"><%= server.server_name ? `${server.server_name} 연결 정보` : `${guildName} 서버 연결 정보` %></p>
  </div>
  <a class="btn btn-ghost" href="<%= backUrl %>">목록으로</a>
</div>

<section class="card">
  <div class="highlight danger">
    <strong>시크릿은 지금만 표시됩니다.</strong>
    <p class="channel-hint">플러그인 설정에 입력한 뒤 별도로 보관하세요.</p>
  </div>

  <div class="grid">
    <div>
      <p class="panel-label">Server ID</p>
      <div class="select-preview">
        <span class="mono"><%= server.server_id %></span>
        <button class="btn btn-ghost" type="button" data-copy="<%= server.server_id %>">복사</button>
      </div>
    </div>
    <div>
      <p class="panel-label">Server Secret</p>
      <div class="select-preview">
        <span class="mono"><%= server.server_secret %></span>
        <button class="btn btn-ghost" type="button" data-copy="<%= server.server_secret %>">복사</button>
      </div>
    </div>
    <% if (serverTarget) { %>
      <p class="channel-hint">대상: <span class="mono"><%= serverTarget %></span></p>
    <% } %>
  </div>
</section>

<script>
  (() => {
    document.querySelectorAll('[data-copy]').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = button.getAttribute('data-copy') || '';
        if (!value) return;
        try {
          await navigator.clipboard.writeText(value);
          button.textContent = '복사됨';
          setTimeout(() => { button.textContent = '복사'; }, 1200);
        } catch (err) {
          button.textContent = '실패';
          setTimeout(() => { button.textContent = '복사'; }, 1200);
        }
      });
    });
  })();
</script>

<%- include('../partials/bottom') %>
