NODE_ENV=production
MINEWIKI_ENV_FILE=/var/www/MineWiki/.env

# Public web/API URLs
NEXT_PUBLIC_SITE_URL=https://minewiki.kr
NEXT_PUBLIC_API_BASE_URL=https://minewiki.kr/api
INTERNAL_API_BASE_URL=http://127.0.0.1:3000

# API
API_HOST=127.0.0.1
API_PORT=3000
DATABASE_URL=postgresql://minewiki:change-me@127.0.0.1:5432/minewiki
REDIS_URL=redis://127.0.0.1:6379
VERIFY_PUBLIC_BASE_URL=https://minewiki.kr

# Auth and sessions
ACCOUNT_LINKING_ENABLED=true
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://minewiki.kr/auth/callback/discord
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://minewiki.kr/auth/callback/naver
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://minewiki.kr/minecraft/callback

# Bot, plugin sync, and worker jobs
DISCORD_BOT_TOKEN=
INTERNAL_BOT_API_TOKEN=change-me
PLUGIN_SYNC_TOKEN=change-me

# Anti-abuse
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Uploads and CDN/static storage
UPLOAD_STORAGE_ROOT=/var/www/MineWiki/apps/cdn/storage
STORAGE_PUBLIC_BASE_URL=https://minewiki.kr/uploads
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="MineWiki <no-reply@minewiki.kr>"

# Observability
LOG_LEVEL=info
SENTRY_DSN=
OBSERVABILITY_ENDPOINT=
OBSERVABILITY_API_KEY=

# Smoke checks
SMOKE_WEB_BASE_URL=http://127.0.0.1:4311
SMOKE_API_BASE_URL=http://127.0.0.1:3000
