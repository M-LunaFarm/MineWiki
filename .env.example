NODE_ENV=production
MINEWIKI_ENV_FILE=/var/www/MineWiki/.env
MINEWIKI_COMPOSE_ENV_FILE=.env

# Docker Compose entrypoint and database credentials (URL-safe passwords only)
MINEWIKI_PUBLIC_URL=http://localhost:8080
MINEWIKI_PORT=8080
MINEWIKI_DB_PASSWORD=change-me
MINEWIKI_DB_ROOT_PASSWORD=change-me

# Public web/API URLs
NEXT_PUBLIC_SITE_URL=https://minewiki.kr
NEXT_PUBLIC_MAIN_SITE_URL=https://minewiki.kr
NEXT_PUBLIC_VERIFY_URL=https://verify.minewiki.kr
NEXT_PUBLIC_API_BASE_URL=https://minewiki.kr/api
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
INTERNAL_API_BASE_URL=http://127.0.0.1:4321
SERVER_WIKI_DOMAIN_TARGET=domains.minewiki.kr
SERVER_WIKI_CERTBOT_EMAIL=support@minewiki.kr
WEBAUTHN_ORIGIN=https://minewiki.kr
WEBAUTHN_RP_ID=minewiki.kr

# API
API_HOST=127.0.0.1
API_PORT=4321
DATABASE_URL=mysql://minewiki:change-me@127.0.0.1:3306/minewiki
REDIS_URL=redis://127.0.0.1:6379
VERIFY_PUBLIC_BASE_URL=https://verify.minewiki.kr
APP_ENCRYPTION_KEY=change-me
WEB_PUSH_ENABLED=false
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@minewiki.kr

# Paddle billing dark launch (off by default; shadow only verifies and records webhooks)
PADDLE_MODE=off
PADDLE_ENV=sandbox
PADDLE_WEBHOOK_SECRET=
PADDLE_WEBHOOK_TOLERANCE_SECONDS=5
PADDLE_API_KEY=
PADDLE_PRICE_HANDBOOK=
PADDLE_PRICE_BRAND=
PADDLE_CHECKOUT_URL=
PADDLE_POLICY_VERSION=2026-07-19-v2.0

# Auth and sessions
ACCOUNT_LINKING_ENABLED=true
WIKI_ANONYMOUS_EDIT_REQUESTS_ENABLED=false
WIKI_ANONYMOUS_DISCUSSIONS_ENABLED=false
WIKI_ANONYMOUS_IP_HASH_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=https://verify.minewiki.kr/minecraft/callback

# Bot, plugin sync, and worker jobs
DISCORD_BOT_TOKEN=
INTERNAL_BOT_API_TOKEN=change-me
PLUGIN_SYNC_TOKEN=change-me

# Anti-abuse
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
NEXT_PUBLIC_WIKI_ANONYMOUS_EDIT_REQUESTS_ENABLED=false
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET_KEY=

# Uploads (host path for PM2; Compose overrides this with its uploads volume)
UPLOAD_STORAGE_ROOT=/var/www/MineWiki/storage/uploads
MINEWIKI_BACKUP_ROOT=/var/backups/minewiki
# rclone destination. The production systemd timer requires this off-host target.
MINEWIKI_BACKUP_REMOTE=
STORAGE_PUBLIC_BASE_URL=https://minewiki.kr/uploads
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Mail
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="MineWiki <no-reply@minewiki.kr>"

# Observability
LOG_LEVEL=info
SENTRY_DSN=
OBSERVABILITY_ENDPOINT=
OBSERVABILITY_API_KEY=

# Smoke checks
SMOKE_WEB_BASE_URL=http://127.0.0.1:4320
SMOKE_API_BASE_URL=http://127.0.0.1:4321
