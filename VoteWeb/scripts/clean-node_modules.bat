@echo off
setlocal

set "ROOT=%~dp0.."
pushd "%ROOT%" || exit /b 1

echo Removing node_modules under %CD% ...
powershell -NoProfile -ExecutionPolicy Bypass -Command ^
  "Get-ChildItem -Path . -Directory -Filter node_modules -Recurse -Force | ForEach-Object { Write-Host ('Deleting ' + $_.FullName); Remove-Item -Recurse -Force -LiteralPath $_.FullName }"

popd
echo Done.
