# ---- Core ----
NODE_ENV=development
LOG_LEVEL=info

# ---- API ----
API_HOST=0.0.0.0
API_PORT=3000
DATABASE_URL=mysql://user:password@localhost:3306/creepervote

# ---- MariaDB (Docker Compose) ----
MARIADB_PORT=3306
MARIADB_ROOT_PASSWORD=creepervote
MARIADB_USER=creepervote
MARIADB_PASSWORD=creepervote
MARIADB_DATABASE=creepervote

# ---- Web ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Auth / SMTP ----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-pass
SMTP_SECURE=false
SMTP_FROM="CreeperVote <no-reply@example.com>"

# ---- Storage ----
UPLOAD_STORAGE_ROOT=./.uploads
STORAGE_ENDPOINT=https://s3.example.com
STORAGE_REGION=us-east-1
STORAGE_BUCKET=creepervote-uploads
STORAGE_ACCESS_KEY=your-storage-key
STORAGE_SECRET_KEY=your-storage-secret
STORAGE_PUBLIC_BASE_URL=https://cdn.example.com

# ---- Worker ----
REDIS_URL=redis://localhost:6379
SERVER_PING_ALLOW_IPV6=false

# ---- Feature Flags ----
ACCOUNT_LINKING_ENABLED=false

# ---- Discord Bot ----
DISCORD_CLIENT_ID=000000000000000000
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://your-app.example.com/auth/callback/discord
DISCORD_BOT_TOKEN=your-discord-bot-token

# ---- NAVER OAuth ----
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_REDIRECT_URI=https://your-app.example.com/auth/callback/naver

# ---- CAPTCHA (옵션) ----
TURNSTILE_SECRET_KEY=your-turnstile-secret
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
HCAPTCHA_SECRET_KEY=your-hcaptcha-secret
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=your-hcaptcha-site-key

# ---- Observability ----
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
OBSERVABILITY_ENDPOINT=https://observability.example.com/ingest
OBSERVABILITY_API_KEY=your-observability-api-key

# ---- Microsoft OAuth ----
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_REDIRECT_URI=https://your-app.example.com/microsoft/callback
