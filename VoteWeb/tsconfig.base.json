{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["dom", "es2021"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@creepervote/config": ["packages/config/src"],
      "@creepervote/logger": ["packages/logger/src"],
      "@creepervote/schemas": ["packages/schemas/src"],
      "@creepervote/analytics": ["packages/analytics/src"],
      "@creepervote/security": ["packages/security/src"],
      "@creepervote/clients": ["packages/clients/src"],
      "@creepervote/ui": ["packages/ui/src"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
