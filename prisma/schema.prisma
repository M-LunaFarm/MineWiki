generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  email
  discord
  naver
}

enum OAuthProvider {
  discord
  naver
}

enum OAuthMode {
  login
  link
}

enum ServerEdition {
  java
  bedrock
}

enum VerificationGrade {
  A
  B
  C
  Unverified
}

enum ReviewVisibility {
  public
  staff
}

enum ClaimMethod {
  plugin
  dns
  motd
}

enum ClaimMethodState {
  pending
  verified
  expired
  failed
}

enum VotifierProtocol {
  v1
  v2
}

enum AccountLinkStatus {
  pending
  linked
}

enum SupportTicketStatus {
  open
  pending
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum SupportMessageAuthorRole {
  customer
  agent
  system
}

model Account {
  id             String       @id @default(uuid())
  provider       AuthProvider
  providerUserId String
  email          String?
  displayName    String?
  avatarUrl      String?
  emailVerified  Boolean      @default(false)
  passwordHash   String?
  createdAt      DateTime     @default(now())
  lastLoginAt    DateTime?

  sessions                Session[]
  emailVerifications      EmailVerification[]
  passwordResets          PasswordReset[]
  minecraftIdentity       MinecraftIdentity?
  minecraftAuthorizations MinecraftAuthorization[]
  oauthStates             OAuthState[]
  linkRequestsSent        AccountLinkRequest[]     @relation("LinkRequestPrimary")
  linkRequestsReceived    AccountLinkRequest[]     @relation("LinkRequestTarget")
  outgoingLinks           AccountLink[]            @relation("AccountLinkPrimary")
  incomingLinks           AccountLink[]            @relation("AccountLinkTarget")
  serversOwned            Server[]                 @relation("ServerOwner")
  reviews                 ServerReview[]
  votes                   Vote[]
  reviewHelpfulVotes      ReviewHelpfulVote[]
  reviewReports           ReviewReport[]
  supportAgentProfile     SupportAgent?
  requestedSupportTickets SupportTicket[]          @relation("SupportTicketRequester")
  assignedSupportTickets  SupportTicket[]          @relation("SupportTicketAssignee")
  supportMessages         SupportMessage[]         @relation("SupportMessageAuthor")
  claimMethods            ServerClaimMethod[]

  @@unique([provider, providerUserId])
  @@index([email])
}

model AccountLink {
  id               String   @id @default(uuid())
  primaryAccountId String
  linkedAccountId  String
  createdAt        DateTime @default(now())

  primaryAccount Account @relation("AccountLinkPrimary", fields: [primaryAccountId], references: [id], onDelete: Cascade)
  linkedAccount  Account @relation("AccountLinkTarget", fields: [linkedAccountId], references: [id], onDelete: Cascade)

  @@unique([primaryAccountId, linkedAccountId])
  @@index([linkedAccountId])
}

model AccountLinkRequest {
  id               String            @id @default(uuid())
  primaryAccountId String
  targetAccountId  String
  verificationCode String
  status           AccountLinkStatus
  createdAt        DateTime          @default(now())
  confirmedAt      DateTime?

  primaryAccount Account @relation("LinkRequestPrimary", fields: [primaryAccountId], references: [id], onDelete: Cascade)
  targetAccount  Account @relation("LinkRequestTarget", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@index([primaryAccountId])
  @@index([targetAccountId])
}

model EmailVerification {
  token     String   @id
  accountId String
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
}

model PasswordReset {
  token     String   @id
  accountId String
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id           String   @id @default(uuid())
  accountId    String
  token        String   @unique
  issuedAt     DateTime
  expiresAt    DateTime
  tokenVersion Int
  isElevated   Boolean  @default(false)
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime
  createdAt    DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model OAuthState {
  state         String        @id
  provider      OAuthProvider
  redirectUri   String
  returnTo      String?
  createdAt     DateTime      @default(now())
  expiresAt     DateTime
  mode          OAuthMode     @default(login)
  linkAccountId String?

  linkAccount Account? @relation(fields: [linkAccountId], references: [id], onDelete: Cascade)
}

model MinecraftAuthorization {
  state        String   @id
  accountId    String
  redirectUri  String
  codeVerifier String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model MinecraftIdentity {
  accountId      String   @id
  uuid           String
  playerName     String?
  msOwned        Boolean
  lastVerifiedAt DateTime

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([uuid])
}

model Server {
  id                    String            @id @default(uuid())
  shortCode             String?           @unique @db.VarChar(12)
  ownerAccountId        String?
  wikiSpaceId           String?
  wikiPageId            String?
  wikiSlug              String?
  name                  String
  joinHost              String
  joinPort              Int
  edition               ServerEdition
  supportedVersions     Json
  tags                  Json
  shortDescription      String
  longDescription       String
  bannerUrl             String?
  websiteUrl            String?
  discordUrl            String?
  voteCooldownHours     Int               @default(24)
  verificationGrade     VerificationGrade @default(Unverified)
  verifiedAt            DateTime?
  votes24h              Int               @default(0)
  votesMonthly          Int?
  reviewsCount          Int               @default(0)
  voteRequiresOwnership Boolean           @default(false)
  playersOnline         Int?
  playersMax            Int?
  playersLastUpdatedAt  DateTime?
  isOnline              Boolean?
  latencyMs             Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  ownerAccount    Account?             @relation("ServerOwner", fields: [ownerAccountId], references: [id], onDelete: SetNull)
  stats           ServerStats?
  pingSamples     ServerPingSample[]
  votes           Vote[]
  reviews         ServerReview[]
  claimMethods    ServerClaimMethod[]
  votifierTargets VotifierTarget[]
  rankSnapshots   ServerRankSnapshot[]
  supportTickets  SupportTicket[]

  @@index([ownerAccountId])
  @@index([wikiSpaceId])
  @@index([wikiSlug])
  @@index([verificationGrade])
  @@index([votes24h])
  @@index([votesMonthly])
  @@index([reviewsCount])
}

model ServerStats {
  serverId             String    @id
  rankCurrent          Int       @default(1)
  rankDelta24h         Int       @default(0)
  rankBest             Int       @default(1)
  votesLast24h         Int       @default(0)
  votesLast7d          Int       @default(0)
  votesMonthToDate     Int       @default(0)
  votesTotal           Int       @default(0)
  playersOnline        Int       @default(0)
  playersMax           Int       @default(0)
  playersLastUpdatedAt DateTime?
  uptimePercent        Float     @default(0)
  sparkline            Json
  latencyMs            Int       @default(0)
  lastPingAt           DateTime?
  lastUpdatedAt        DateTime  @default(now()) @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model ServerPingSample {
  id         String   @id @default(uuid())
  serverId   String
  timestamp  DateTime
  online     Boolean
  players    Int?
  maxPlayers Int?
  latency    Int?
  motd       String?
  version    String?
  createdAt  DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
}

model Vote {
  id                 String   @id @default(uuid())
  serverId           String
  accountId          String?
  minecraftUuid      String?
  username           String
  usernameNormalized String
  ipAddress          String?
  votedAt            DateTime
  createdAt          DateTime @default(now())

  server  Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([serverId, votedAt])
  @@index([serverId, accountId])
  @@index([serverId, minecraftUuid])
  @@index([serverId, usernameNormalized])
  @@index([serverId, ipAddress])
}

model ServerReview {
  id                  String           @id @default(uuid())
  serverId            String
  authorAccountId     String
  authorDisplayName   String
  rating              Int
  body                String
  tags                Json
  visibility          ReviewVisibility @default(public)
  isAnonymous         Boolean          @default(false)
  helpfulCount        Int              @default(0)
  reports             Int              @default(0)
  adminReplyBody      String?
  adminReplyAuthor    String?
  adminReplyCreatedAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  server        Server              @relation(fields: [serverId], references: [id], onDelete: Cascade)
  authorAccount Account             @relation(fields: [authorAccountId], references: [id], onDelete: Cascade)
  helpfulVotes  ReviewHelpfulVote[]
  reportsBy     ReviewReport[]

  @@index([serverId, createdAt])
  @@index([serverId, visibility])
}

model ReviewHelpfulVote {
  id           String   @id @default(uuid())
  reviewId     String
  accountId    String
  isHelpful    Boolean  @default(true)
  lastMarkedAt DateTime
  createdAt    DateTime @default(now())

  review  ServerReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([reviewId, accountId])
  @@index([accountId])
}

model ReviewReport {
  id        String   @id @default(uuid())
  reviewId  String
  accountId String
  createdAt DateTime @default(now())

  review  ServerReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([reviewId, accountId])
  @@index([accountId])
}

model ServerClaimMethod {
  id            String           @id @default(uuid())
  serverId      String
  accountId     String?
  method        ClaimMethod
  token         String
  issuedAt      DateTime
  status        ClaimMethodState @default(pending)
  verifiedAt    DateTime?
  lastCheckedAt DateTime?
  note          String?

  server  Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([serverId, method])
  @@index([accountId])
}

model VotifierTarget {
  id        String           @id @default(uuid())
  serverId  String
  protocol  VotifierProtocol
  host      String
  port      Int
  token     String?
  publicKey String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId])
}

model ServerRankSnapshot {
  id               String   @id @default(uuid())
  serverId         String
  rank             Int
  votes24h         Int
  votesMonthToDate Int
  recordedAt       DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, recordedAt])
}

model SupportAgent {
  accountId   String   @id
  displayName String?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id                 String                @id @default(uuid())
  requesterAccountId String
  assigneeAccountId  String?
  serverId           String?
  subject            String
  status             SupportTicketStatus   @default(open)
  priority           SupportTicketPriority @default(normal)
  category           String?
  lastMessageAt      DateTime              @default(now())
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  requesterAccount Account          @relation("SupportTicketRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)
  assigneeAccount  Account?         @relation("SupportTicketAssignee", fields: [assigneeAccountId], references: [id], onDelete: SetNull)
  server           Server?          @relation(fields: [serverId], references: [id], onDelete: SetNull)
  messages         SupportMessage[]

  @@index([requesterAccountId, createdAt])
  @@index([assigneeAccountId, status])
  @@index([status, lastMessageAt])
  @@index([serverId])
}

model SupportMessage {
  id              String                   @id @default(uuid())
  ticketId        String
  authorAccountId String?
  authorRole      SupportMessageAuthorRole
  body            String
  isInternal      Boolean                  @default(false)
  createdAt       DateTime                 @default(now())

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorAccount Account?      @relation("SupportMessageAuthor", fields: [authorAccountId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([authorAccountId])
  @@index([isInternal])
}

model DiscordSubscription {
  guildId      String   @id
  channelId    String
  timezone     String
  roleRewardId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  nextDigestAt DateTime
}

model DiscordVerificationSession {
  id                 String    @id @default(uuid())
  status             String    @default("pending")
  guildId            String
  channelId          String
  requesterDiscordId String
  accountId          String?
  minecraftUuid      String?
  minecraftName      String?
  roleId             String?
  nicknameTemplate   String?
  verificationUrl    String?
  eventLog           Json?
  syncAttempts       Int       @default(0)
  lastSyncStatus     String?
  createdAt          DateTime  @default(now())
  expiresAt          DateTime
  completedAt        DateTime?
  lastSyncAt         DateTime?

  @@index([guildId, requesterDiscordId])
  @@index([accountId])
  @@index([status, expiresAt])
}

model ServerPluginSyncEvent {
  id             String   @id @default(uuid())
  serverId       String?
  pluginServerId String?
  discordUserId  String?
  minecraftUuid  String
  playerName     String?
  action         String
  payload        Json?
  createdAt      DateTime @default(now())

  @@index([serverId, createdAt])
  @@index([minecraftUuid, createdAt])
  @@index([discordUserId, createdAt])
}

model WikiProfile {
  id                      BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  accountId               String?   @unique @map("account_id") @db.Char(36)
  username                String    @unique @db.VarChar(64)
  displayName             String    @map("display_name") @db.VarChar(64)
  email                   String?   @unique @db.VarChar(255)
  emailVerifiedAt         DateTime? @map("email_verified_at")
  emailVerificationSentAt DateTime? @map("email_verification_sent_at")
  passwordHash            String?   @map("password_hash") @db.VarChar(255)
  status                  String    @default("active") @db.VarChar(32)
  createdAt               DateTime  @map("created_at")
  updatedAt               DateTime  @map("updated_at")

  @@index([createdAt])
  @@map("users")
}

model WikiSpace {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  code              String   @unique @db.VarChar(64)
  spaceKey          String?  @unique @map("space_key") @db.VarChar(64)
  name              String   @db.VarChar(128)
  title             String?  @db.VarChar(255)
  slug              String?  @unique @db.VarChar(255)
  spaceType         String   @default("basic") @map("space_type") @db.VarChar(32)
  parentSpaceId     BigInt?  @map("parent_space_id") @db.UnsignedBigInt
  rootPageId        BigInt?  @map("root_page_id") @db.UnsignedBigInt
  rootNamespaceCode String   @map("root_namespace_code") @db.VarChar(32)
  rootPath          String   @unique @map("root_path") @db.VarChar(128)
  description       String?  @db.Text
  status            String   @default("active") @db.VarChar(32)
  createdBy         BigInt?  @map("created_by") @db.UnsignedBigInt
  ownerUserId       BigInt?  @map("owner_user_id") @db.UnsignedBigInt
  ownerPageId       BigInt?  @map("owner_page_id") @db.UnsignedBigInt
  createdAt         DateTime @map("created_at")
  updatedAt         DateTime @map("updated_at")

  @@index([spaceType, status])
  @@index([parentSpaceId])
  @@map("wiki_spaces")
}

model WikiNamespace {
  id          Int     @id @default(autoincrement()) @db.UnsignedInt
  code        String  @unique @db.VarChar(32)
  displayName String  @map("display_name") @db.VarChar(64)
  pathPrefix  String  @map("path_prefix") @db.VarChar(64)
  isContent   Boolean @default(true) @map("is_content")

  @@map("namespaces")
}

model WikiPage {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  namespaceId       Int      @map("namespace_id") @db.UnsignedInt
  spaceId           BigInt   @map("space_id") @db.UnsignedBigInt
  localPath         String   @map("local_path") @db.VarChar(500)
  slug              String   @db.VarChar(255)
  title             String   @db.VarChar(255)
  displayTitle      String   @map("display_title") @db.VarChar(255)
  currentRevisionId BigInt?  @map("current_revision_id") @db.UnsignedBigInt
  pageType          String   @default("article") @map("page_type") @db.VarChar(32)
  protectionLevel   String   @default("open") @map("protection_level") @db.VarChar(32)
  status            String   @default("normal") @db.VarChar(32)
  createdBy         BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt         DateTime @map("created_at")
  updatedAt         DateTime @map("updated_at")

  @@unique([namespaceId, slug])
  @@unique([spaceId, localPath])
  @@index([spaceId])
  @@index([title])
  @@index([pageType])
  @@index([updatedAt])
  @@map("pages")
}

model WikiPageRevision {
  id               BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  pageId           BigInt   @map("page_id") @db.UnsignedBigInt
  revisionNo       Int      @map("revision_no") @db.UnsignedInt
  parentRevisionId BigInt?  @map("parent_revision_id") @db.UnsignedBigInt
  contentRaw       String   @map("content_raw") @db.MediumText
  contentAst       Json?    @map("content_ast")
  contentHash      String   @map("content_hash") @db.Char(64)
  contentSize      Int      @default(0) @map("content_size") @db.UnsignedInt
  syntaxVersion    String   @default("bwm-0.3") @map("syntax_version") @db.VarChar(32)
  editSummary      String?  @map("edit_summary") @db.VarChar(255)
  isMinor          Boolean  @default(false) @map("is_minor")
  editTags         Json?    @map("edit_tags")
  createdBy        BigInt?  @map("created_by") @db.UnsignedBigInt
  actorType        String   @default("user") @map("actor_type") @db.VarChar(16)
  actorUserId      BigInt?  @map("actor_user_id") @db.UnsignedBigInt
  actorIp          Bytes?   @map("actor_ip") @db.VarBinary(16)
  actorIpText      String?  @map("actor_ip_text") @db.VarChar(45)
  actorIpHash      String?  @map("actor_ip_hash") @db.Char(64)
  createdAt        DateTime @map("created_at")
  visibility       String   @default("public") @db.VarChar(32)

  @@unique([pageId, revisionNo])
  @@index([parentRevisionId])
  @@index([pageId, createdAt])
  @@index([createdAt])
  @@index([createdBy, createdAt])
  @@index([actorUserId])
  @@index([actorIpHash])
  @@index([visibility])
  @@index([contentHash])
  @@map("page_revisions")
}

model WikiPageRenderCache {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  pageId          BigInt   @map("page_id") @db.UnsignedBigInt
  revisionId      BigInt   @map("revision_id") @db.UnsignedBigInt
  rendererVersion String   @map("renderer_version") @db.VarChar(32)
  html            String   @db.MediumText
  tocJson         Json?    @map("toc_json")
  headingsJson    Json?    @map("headings_json")
  warningsJson    Json?    @map("warnings_json")
  footnotesJson   Json?    @map("footnotes_json")
  linksJson       Json?    @map("links_json")
  categoriesJson  Json?    @map("categories_json")
  componentsJson  Json?    @map("components_json")
  createdAt       DateTime @map("created_at")

  @@unique([revisionId, rendererVersion])
  @@index([pageId])
  @@map("page_render_cache")
}

model ServerWiki {
  id                BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  spaceId           BigInt   @map("space_id") @db.UnsignedBigInt
  voteServerId      String?  @unique @map("vote_server_id") @db.Char(36)
  serverName        String   @map("server_name") @db.VarChar(255)
  slug              String   @unique @db.VarChar(255)
  host              String?  @db.VarChar(255)
  port              Int?     @db.UnsignedInt
  edition           String   @default("unknown") @db.VarChar(16)
  supportedVersions String?  @map("supported_versions") @db.VarChar(255)
  genres            String?  @db.VarChar(255)
  verifiedStatus    String   @default("none") @map("verified_status") @db.VarChar(32)
  status            String   @default("active") @db.VarChar(32)
  createdBy         BigInt?  @map("created_by") @db.UnsignedBigInt
  createdAt         DateTime @map("created_at")
  updatedAt         DateTime @map("updated_at")

  @@index([spaceId])
  @@index([status])
  @@index([verifiedStatus])
  @@map("server_wikis")
}

model ModWiki {
  id                BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  spaceId           BigInt    @map("space_id") @db.UnsignedBigInt
  modName           String    @map("mod_name") @db.VarChar(255)
  category          String?   @db.VarChar(128)
  slug              String    @unique @db.VarChar(255)
  loaders           String?   @db.VarChar(255)
  supportedVersions String?   @map("supported_versions") @db.Text
  officialUrl       String?   @map("official_url") @db.VarChar(500)
  sourceUrl         String?   @map("source_url") @db.VarChar(500)
  license           String?   @db.VarChar(128)
  creatorVerified   Boolean   @default(false) @map("creator_verified")
  verifiedBy        BigInt?   @map("verified_by") @db.UnsignedBigInt
  verifiedAt        DateTime? @map("verified_at")
  status            String    @default("active") @db.VarChar(32)
  lastChecked       DateTime? @map("last_checked") @db.Date
  createdAt         DateTime  @map("created_at")
  updatedAt         DateTime  @map("updated_at")

  @@index([spaceId])
  @@index([status])
  @@map("mod_wikis")
}

model SubwikiRole {
  id        BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  spaceId   BigInt    @map("space_id") @db.UnsignedBigInt
  userId    BigInt    @map("user_id") @db.UnsignedBigInt
  role      String    @default("editor") @db.VarChar(64)
  status    String    @default("active") @db.VarChar(32)
  grantedBy BigInt?   @map("granted_by") @db.UnsignedBigInt
  grantedAt DateTime  @map("granted_at")
  revokedAt DateTime? @map("revoked_at")
  revokedBy BigInt?   @map("revoked_by") @db.UnsignedBigInt

  @@unique([spaceId, userId, role])
  @@index([userId])
  @@index([spaceId])
  @@map("subwiki_roles")
}

model DocumentTemplate {
  id              BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  spaceId         BigInt?  @map("space_id") @db.UnsignedBigInt
  templateKey     String   @map("template_key") @db.VarChar(128)
  title           String   @db.VarChar(255)
  description     String?  @db.Text
  templateScope   String   @default("space") @map("template_scope") @db.VarChar(32)
  targetArea      String   @default("any") @map("target_area") @db.VarChar(32)
  defaultCategory String?  @map("default_category") @db.VarChar(255)
  contentRaw      String   @map("content_raw") @db.MediumText
  createdBy       BigInt?  @map("created_by") @db.UnsignedBigInt
  status          String   @default("active") @db.VarChar(32)
  createdAt       DateTime @map("created_at")
  updatedAt       DateTime @map("updated_at")

  @@unique([spaceId, templateKey])
  @@index([spaceId])
  @@index([templateScope])
  @@index([status])
  @@map("document_templates")
}
