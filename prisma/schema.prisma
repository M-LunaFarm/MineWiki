generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  email
  discord
  naver
}

enum OAuthProvider {
  discord
  naver
}

enum OAuthMode {
  login
  link
}

enum ServerEdition {
  java
  bedrock
}

enum ServerListingStatus {
  pending
  active
  suspended
}

enum VerificationGrade {
  A
  B
  C
  Unverified
}

enum PlayerMetricTrust {
  trusted
  self_reported
  anomalous
  unknown
}

enum PlayerMetricSource {
  status_ping
}

enum ReviewVisibility {
  public
  staff
}

enum ReviewReportStatus {
  open
  in_review
  resolved
  dismissed
}

enum WikiReportTargetType {
  page
  revision
  discussion
  comment
}

enum WikiReportStatus {
  open
  in_review
  resolved
  dismissed
}

enum ClaimMethod {
  plugin
  dns
  motd
}

enum ClaimMethodState {
  pending
  verified
  expired
  failed
}

enum VotifierProtocol {
  v1
  v2
}

enum AccountLinkStatus {
  pending
  linked
}

enum SupportTicketStatus {
  open
  pending
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum SupportMessageAuthorRole {
  customer
  agent
  system
}

model Account {
  id                  String       @id @default(uuid())
  canonicalAccountId  String?
  provider            AuthProvider
  providerUserId      String
  email               String?
  displayName         String?
  avatarUrl           String?
  emailVerified       Boolean      @default(false)
  passwordHash        String?
  createdAt           DateTime     @default(now())
  lastLoginAt         DateTime?
  lifecycleStatus     String       @default("active") @map("lifecycle_status") @db.VarChar(32)
  deletionRequestedAt DateTime?    @map("deletion_requested_at") @db.DateTime(3)
  anonymizedAt        DateTime?    @map("anonymized_at") @db.DateTime(3)
  suspendedAt         DateTime?    @map("suspended_at") @db.DateTime(3)
  suspendedBy         String?      @map("suspended_by") @db.VarChar(191)
  suspensionReason    String?      @map("suspension_reason") @db.VarChar(1000)

  sessions                Session[]
  emailVerifications      EmailVerification[]
  passwordResets          PasswordReset[]
  minecraftIdentities     MinecraftIdentity[]
  minecraftAuthorizations MinecraftAuthorization[]
  oauthStates             OAuthState[]
  oauthCredentials        OAuthCredential[]
  linkRequestsSent        AccountLinkRequest[]     @relation("LinkRequestPrimary")
  linkRequestsReceived    AccountLinkRequest[]     @relation("LinkRequestTarget")
  outgoingLinks           AccountLink[]            @relation("AccountLinkPrimary")
  incomingLinks           AccountLink[]            @relation("AccountLinkTarget")
  serversOwned            Server[]                 @relation("ServerOwner")
  serversRegistered       Server[]                 @relation("ServerRegistrant")
  reviews                 ServerReview[]
  votes                   Vote[]
  reviewHelpfulVotes      ReviewHelpfulVote[]
  reviewReports           ReviewReport[]           @relation("ReviewReportReporter")
  assignedReviewReports   ReviewReport[]           @relation("ReviewReportAssignee")
  supportAgentProfile     SupportAgent?
  requestedSupportTickets SupportTicket[]          @relation("SupportTicketRequester")
  assignedSupportTickets  SupportTicket[]          @relation("SupportTicketAssignee")
  supportMessages         SupportMessage[]         @relation("SupportMessageAuthor")
  claimMethods            ServerClaimMethod[]
  accountRoles            AccountRole[]
  consents                AccountConsent[]
  mfaTotpCredential       MfaTotpCredential?
  mfaRecoveryCodes        MfaRecoveryCode[]
  webAuthnCredentials     WebAuthnCredential[]
  webAuthnChallenges      WebAuthnChallenge[]
  wikiApiTokens           WikiApiToken[]

  @@unique([provider, providerUserId])
  @@index([email])
  @@index([canonicalAccountId])
  @@index([lifecycleStatus, deletionRequestedAt])
  @@index([lifecycleStatus, suspendedAt])
}

model AccountDeletionRequest {
  id                 String    @id @default(uuid()) @db.Char(36)
  canonicalAccountId String    @unique @map("canonical_account_id") @db.Char(36)
  accountIds         Json      @map("account_ids")
  status             String    @default("requested") @db.VarChar(32)
  reauthMethod       String    @map("reauth_method") @db.VarChar(32)
  cancelTokenHash    String    @unique @map("cancel_token_hash") @db.Char(64)
  blockerSnapshot    Json?     @map("blocker_snapshot")
  requestedBy        String    @map("requested_by") @db.Char(36)
  requestedAt        DateTime  @default(now()) @map("requested_at") @db.DateTime(3)
  scheduledFor       DateTime  @map("scheduled_for") @db.DateTime(3)
  cancelledAt        DateTime? @map("cancelled_at") @db.DateTime(3)
  cancelledBy        String?   @map("cancelled_by") @db.VarChar(64)
  processedAt        DateTime? @map("processed_at") @db.DateTime(3)
  processedBy        String?   @map("processed_by") @db.Char(36)
  adminNote          String?   @map("admin_note") @db.VarChar(1000)
  version            Int       @default(1)
  createdAt          DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  @@index([status, scheduledFor])
  @@map("account_deletion_requests")
}

model AccountDeletionDiscordRevocation {
  id                    String    @id @default(uuid()) @db.Char(36)
  dedupeKey             String    @unique @map("dedupe_key") @db.VarChar(191)
  deletionRequestId     String    @map("deletion_request_id") @db.Char(36)
  verificationSessionId String?   @map("verification_session_id") @db.VarChar(191)
  guildId               String    @map("guild_id") @db.VarChar(32)
  discordUserId         String?   @map("discord_user_id") @db.VarChar(32)
  roleId                String?   @map("role_id") @db.VarChar(32)
  status                String    @default("pending") @db.VarChar(32)
  attempts              Int       @default(0)
  availableAt           DateTime  @default(now()) @map("available_at") @db.DateTime(3)
  lockedAt              DateTime? @map("locked_at") @db.DateTime(3)
  lockedBy              String?   @map("locked_by") @db.VarChar(64)
  processedAt           DateTime? @map("processed_at") @db.DateTime(3)
  lastError             String?   @map("last_error") @db.VarChar(500)
  createdAt             DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  @@index([status, availableAt])
  @@index([deletionRequestId])
  @@map("account_deletion_discord_revocations")
}

model AccountConsent {
  id            String   @id @default(uuid())
  accountId     String   @map("account_id")
  consentType   String   @map("consent_type") @db.VarChar(32)
  policyVersion String   @map("policy_version") @db.VarChar(32)
  consentedAt   DateTime @default(now()) @map("consented_at") @db.DateTime(3)
  ipAddress     String?  @map("ip_address") @db.VarChar(45)
  userAgent     String?  @map("user_agent") @db.VarChar(512)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, consentType, policyVersion])
  @@index([consentType, policyVersion])
  @@map("account_consents")
}

model GlobalRole {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(64)
  displayName String   @map("display_name") @db.VarChar(128)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  accountRoles    AccountRole[]
  rolePermissions RolePermission[]

  @@map("global_roles")
}

model AccountRole {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  account Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role    GlobalRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([accountId, roleId])
  @@index([roleId])
  @@map("account_roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(128)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)

  role       GlobalRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditEvent {
  id             String   @id @default(uuid()) @db.Char(36)
  category       String   @db.VarChar(64)
  action         String   @db.VarChar(128)
  severity       String   @default("info") @db.VarChar(16)
  actorAccountId String?  @map("actor_account_id")
  actorProfileId BigInt?  @map("actor_profile_id")
  subjectType    String?  @map("subject_type") @db.VarChar(64)
  subjectId      String?  @map("subject_id") @db.VarChar(128)
  requestId      String?  @map("request_id") @db.VarChar(64)
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.VarChar(512)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([actorAccountId, createdAt])
  @@index([subjectType, subjectId, createdAt])
  @@map("audit_events")
}

model SiteSetting {
  key         String   @id @db.VarChar(128)
  value       Json
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("site_settings")
}

model AccountLink {
  id               String   @id @default(uuid())
  primaryAccountId String
  linkedAccountId  String
  createdAt        DateTime @default(now())

  primaryAccount Account @relation("AccountLinkPrimary", fields: [primaryAccountId], references: [id], onDelete: Cascade)
  linkedAccount  Account @relation("AccountLinkTarget", fields: [linkedAccountId], references: [id], onDelete: Cascade)

  @@unique([primaryAccountId, linkedAccountId])
  @@index([linkedAccountId])
}

model AccountLinkRequest {
  id               String            @id @default(uuid())
  primaryAccountId String
  targetAccountId  String
  verificationCode String
  status           AccountLinkStatus
  createdAt        DateTime          @default(now())
  confirmedAt      DateTime?

  primaryAccount Account @relation("LinkRequestPrimary", fields: [primaryAccountId], references: [id], onDelete: Cascade)
  targetAccount  Account @relation("LinkRequestTarget", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@index([primaryAccountId])
  @@index([targetAccountId])
}

model EmailVerification {
  token     String   @id
  accountId String
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
}

model AccountEmailChange {
  id                   String    @id @default(uuid()) @db.Char(36)
  canonicalAccountId   String    @map("canonical_account_id") @db.Char(36)
  credentialAccountId  String?   @map("credential_account_id") @db.Char(36)
  previousEmail        String?   @map("previous_email") @db.VarChar(254)
  newEmail             String    @map("new_email") @db.VarChar(254)
  tokenHash            String    @unique @map("token_hash") @db.Char(64)
  groupFingerprint     String    @map("group_fingerprint") @db.Char(64)
  status               String    @default("pending") @db.VarChar(16)
  activeKey            String?   @unique @map("active_key") @db.Char(36)
  requestedBySessionId String    @map("requested_by_session_id") @db.Char(36)
  sentAt               DateTime  @map("sent_at") @db.DateTime(3)
  resendAvailableAt    DateTime  @map("resend_available_at") @db.DateTime(3)
  expiresAt            DateTime  @map("expires_at") @db.DateTime(3)
  confirmedAt          DateTime? @map("confirmed_at") @db.DateTime(3)
  supersededAt         DateTime? @map("superseded_at") @db.DateTime(3)
  createdAt            DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt            DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  @@index([canonicalAccountId, status, createdAt], map: "idx_account_email_changes_account")
  @@index([newEmail, status], map: "idx_account_email_changes_new_email")
  @@index([expiresAt], map: "idx_account_email_changes_expiry")
  @@map("account_email_changes")
}

model PasswordReset {
  token     String   @id
  accountId String
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id                     String    @id @default(uuid())
  accountId              String
  token                  String    @unique
  issuedAt               DateTime
  expiresAt              DateTime
  tokenVersion           Int
  isElevated             Boolean   @default(false)
  primaryAuthenticatedAt DateTime  @default(now()) @map("primary_authenticated_at") @db.DateTime(3)
  stepUpAt               DateTime? @map("step_up_at") @db.DateTime(3)
  stepUpExpiresAt        DateTime? @map("step_up_expires_at") @db.DateTime(3)
  stepUpMethod           String?   @map("step_up_method") @db.VarChar(32)
  stepUpPurpose          String?   @map("step_up_purpose") @db.VarChar(64)
  ipAddress              String?
  userAgent              String?
  lastActiveAt           DateTime
  termsPolicyVersion     String?   @map("terms_policy_version") @db.VarChar(32)
  privacyPolicyVersion   String?   @map("privacy_policy_version") @db.VarChar(32)
  createdAt              DateTime  @default(now())

  account              Account               @relation(fields: [accountId], references: [id], onDelete: Cascade)
  wikiPushSubscription WikiPushSubscription?
  webAuthnChallenges   WebAuthnChallenge[]

  @@index([accountId])
  @@index([expiresAt])
  @@index([termsPolicyVersion, privacyPolicyVersion])
  @@index([stepUpExpiresAt])
}

model MfaTotpCredential {
  id               String    @id @default(uuid()) @db.Char(36)
  accountId        String    @unique @map("account_id")
  secretCiphertext String    @map("secret_ciphertext") @db.Text
  pendingExpiresAt DateTime? @map("pending_expires_at") @db.DateTime(3)
  enabledAt        DateTime? @map("enabled_at") @db.DateTime(3)
  lastUsedStep     BigInt?   @map("last_used_step") @db.UnsignedBigInt
  failedAttempts   Int       @default(0) @map("failed_attempts") @db.UnsignedInt
  lockedUntil      DateTime? @map("locked_until") @db.DateTime(3)
  createdAt        DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("mfa_totp_credentials")
}

model MfaRecoveryCode {
  id        String    @id @default(uuid()) @db.Char(36)
  accountId String    @map("account_id")
  codeHash  String    @map("code_hash") @db.Char(64)
  usedAt    DateTime? @map("used_at") @db.DateTime(3)
  createdAt DateTime  @default(now()) @map("created_at") @db.DateTime(3)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, codeHash])
  @@index([accountId, usedAt])
  @@map("mfa_recovery_codes")
}

model WebAuthnCredential {
  id             String    @id @default(uuid()) @db.Char(36)
  accountId      String    @map("account_id")
  credentialId   String    @unique @map("credential_id") @db.VarChar(512)
  name           String    @db.VarChar(64)
  publicKey      Bytes     @map("public_key") @db.Blob
  counter        BigInt    @default(0) @db.UnsignedBigInt
  counterVersion Int       @default(0) @map("counter_version") @db.UnsignedInt
  transports     Json?
  deviceType     String    @map("device_type") @db.VarChar(32)
  backedUp       Boolean   @default(false) @map("backed_up")
  lastUsedAt     DateTime? @map("last_used_at") @db.DateTime(3)
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, name])
  @@index([accountId, createdAt])
  @@map("webauthn_credentials")
}

model WebAuthnChallenge {
  id                  String    @id @default(uuid()) @db.Char(36)
  accountId           String    @map("account_id")
  sessionId           String    @map("session_id")
  sessionTokenVersion Int       @map("session_token_version") @db.UnsignedInt
  operation           String    @db.VarChar(32)
  purpose             String?   @db.VarChar(64)
  challenge           String    @unique @db.VarChar(255)
  expiresAt           DateTime  @map("expires_at") @db.DateTime(3)
  consumedAt          DateTime? @map("consumed_at") @db.DateTime(3)
  createdAt           DateTime  @default(now()) @map("created_at") @db.DateTime(3)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([accountId, sessionId, operation, purpose, consumedAt], map: "webauthn_challenge_lookup_idx")
  @@index([expiresAt])
  @@map("webauthn_challenges")
}

model OAuthState {
  state              String        @id
  provider           OAuthProvider
  redirectUri        String
  returnTo           String?
  createdAt          DateTime      @default(now())
  expiresAt          DateTime
  mode               OAuthMode     @default(login)
  linkAccountId      String?
  agreeTerms         Boolean       @default(false)
  agreePrivacy       Boolean       @default(false)
  browserBindingHash String?       @map("browser_binding_hash") @db.Char(64)

  linkAccount Account? @relation(fields: [linkAccountId], references: [id], onDelete: Cascade)
}

model OAuthPendingSignup {
  id                 String        @id @db.Char(64)
  provider           OAuthProvider
  payloadEncrypted   String        @map("payload_encrypted") @db.Text
  returnTo           String?       @map("return_to") @db.VarChar(2048)
  browserBindingHash String        @map("browser_binding_hash") @db.Char(64)
  createdAt          DateTime      @default(now()) @map("created_at") @db.DateTime(3)
  expiresAt          DateTime      @map("expires_at") @db.DateTime(3)

  @@index([expiresAt], map: "idx_oauth_pending_signups_expires")
  @@map("oauth_pending_signups")
}

model OAuthCredential {
  id             String        @id @default(uuid())
  accountId      String
  provider       OAuthProvider
  providerUserId String
  accessToken    String        @db.Text
  refreshToken   String?       @db.Text
  tokenType      String?       @db.VarChar(32)
  scope          String?       @db.VarChar(512)
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, provider, providerUserId])
  @@index([provider, providerUserId])
  @@index([expiresAt])
  @@map("oauth_credentials")
}

model MinecraftAuthorization {
  state        String   @id
  accountId    String
  redirectUri  String
  codeVerifier String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model MinecraftIdentity {
  id             BigInt   @id @default(autoincrement()) @db.UnsignedBigInt
  accountId      String
  uuid           String   @unique
  playerName     String?
  msOwned        Boolean
  isPrimary      Boolean  @default(false)
  lastVerifiedAt DateTime

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, isPrimary])
}

model Server {
  id                      String              @id @default(uuid())
  shortCode               String?             @unique @db.VarChar(12)
  ownerAccountId          String?
  registrantAccountId     String?
  registrationEndpointKey String?             @unique @db.Char(64)
  wikiSpaceId             BigInt?             @unique @db.UnsignedBigInt
  wikiPageId              BigInt?             @unique @db.UnsignedBigInt
  wikiSlug                String?
  name                    String
  joinHost                String
  joinPort                Int
  edition                 ServerEdition
  listingStatus           ServerListingStatus @default(pending)
  supportedVersions       Json
  tags                    Json
  shortDescription        String
  longDescription         String
  bannerUrl               String?
  websiteUrl              String?
  discordUrl              String?
  voteCooldownHours       Int                 @default(24)
  verificationGrade       VerificationGrade   @default(Unverified)
  verifiedAt              DateTime?
  votes24h                Int                 @default(0)
  votesMonthly            Int?
  reviewsCount            Int                 @default(0)
  voteRequiresOwnership   Boolean             @default(false)
  playersOnline           Int?
  playersMax              Int?
  playersLastUpdatedAt    DateTime?
  playersMetricTrust      PlayerMetricTrust   @default(unknown)
  playersMetricSource     PlayerMetricSource?
  playersAnomalyReason    String?             @db.VarChar(64)
  isOnline                Boolean?
  latencyMs               Int?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  ownerAccount         Account?              @relation("ServerOwner", fields: [ownerAccountId], references: [id], onDelete: SetNull)
  registrantAccount    Account?              @relation("ServerRegistrant", fields: [registrantAccountId], references: [id], onDelete: SetNull)
  stats                ServerStats?
  pingSamples          ServerPingSample[]
  votes                Vote[]
  voteDispatchAttempts VoteDispatchAttempt[]
  reviews              ServerReview[]
  claimMethods         ServerClaimMethod[]
  votifierTargets      VotifierTarget[]
  rankSnapshots        ServerRankSnapshot[]
  supportTickets       SupportTicket[]
  wikiSpace            WikiSpace?            @relation("ServerLinkedWikiSpace", fields: [wikiSpaceId], references: [id], onDelete: SetNull)
  wikiPage             WikiPage?             @relation("ServerLinkedWikiPage", fields: [wikiPageId], references: [id], onDelete: SetNull)

  @@index([ownerAccountId])
  @@index([registrantAccountId])
  @@index([wikiSpaceId])
  @@index([wikiSlug])
  @@index([verificationGrade])
  @@index([listingStatus])
  @@index([votes24h])
  @@index([votesMonthly])
  @@index([reviewsCount])
  @@index([playersMetricTrust, playersOnline])
}

model ServerStats {
  serverId             String    @id
  rankCurrent          Int       @default(1)
  rankDelta24h         Int       @default(0)
  rankBest             Int       @default(1)
  votesLast24h         Int       @default(0)
  votesLast7d          Int       @default(0)
  votesMonthToDate     Int       @default(0)
  votesTotal           Int       @default(0)
  playersOnline        Int       @default(0)
  playersMax           Int       @default(0)
  playersLastUpdatedAt DateTime?
  uptimePercent        Float     @default(0)
  sparkline            Json
  latencyMs            Int       @default(0)
  lastPingAt           DateTime?
  rankCalculatedAt     DateTime? @map("rank_calculated_at") @db.DateTime(3)
  lastUpdatedAt        DateTime  @default(now()) @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([rankCalculatedAt])
}

model ServerPingSample {
  id                   String              @id @default(uuid())
  serverId             String
  timestamp            DateTime
  online               Boolean
  players              Int?
  maxPlayers           Int?
  playersMetricTrust   PlayerMetricTrust   @default(unknown)
  playersMetricSource  PlayerMetricSource?
  playersAnomalyReason String?             @db.VarChar(64)
  latency              Int?
  motd                 String?
  version              String?
  createdAt            DateTime            @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
}

model Vote {
  id                 String    @id @default(uuid())
  serverId           String
  accountId          String?
  minecraftUuid      String?
  username           String
  usernameNormalized String
  ipAddress          String?
  votedAt            DateTime
  createdAt          DateTime  @default(now())
  status             String    @default("valid") @db.VarChar(16)
  invalidatedAt      DateTime? @map("invalidated_at") @db.DateTime(3)
  invalidatedBy      String?   @map("invalidated_by") @db.VarChar(191)
