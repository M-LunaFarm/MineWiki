generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  email
  discord
  naver
}

enum OAuthProvider {
  discord
  naver
}

enum OAuthMode {
  login
  link
}

enum ServerEdition {
  java
  bedrock
}

enum VerificationGrade {
  A
  B
  C
  Unverified
}

enum ReviewVisibility {
  public
  staff
}

enum ClaimMethod {
  plugin
  dns
  motd
}

enum ClaimMethodState {
  pending
  verified
  expired
  failed
}

enum VotifierProtocol {
  v1
  v2
}

enum AccountLinkStatus {
  pending
  linked
}

enum SupportTicketStatus {
  open
  pending
  resolved
  closed
}

enum SupportTicketPriority {
  low
  normal
  high
  urgent
}

enum SupportMessageAuthorRole {
  customer
  agent
  system
}

model Account {
  id             String       @id @default(uuid())
  provider       AuthProvider
  providerUserId String
  email          String?
  displayName    String?
  avatarUrl      String?
  emailVerified  Boolean      @default(false)
  passwordHash   String?
  createdAt      DateTime     @default(now())
  lastLoginAt    DateTime?

  sessions                Session[]
  emailVerifications      EmailVerification[]
  passwordResets          PasswordReset[]
  minecraftIdentity       MinecraftIdentity?
  minecraftAuthorizations MinecraftAuthorization[]
  oauthStates             OAuthState[]
  oauthCredentials        OAuthCredential[]
  linkRequestsSent        AccountLinkRequest[]     @relation("LinkRequestPrimary")
  linkRequestsReceived    AccountLinkRequest[]     @relation("LinkRequestTarget")
  outgoingLinks           AccountLink[]            @relation("AccountLinkPrimary")
  incomingLinks           AccountLink[]            @relation("AccountLinkTarget")
  serversOwned            Server[]                 @relation("ServerOwner")
  reviews                 ServerReview[]
  votes                   Vote[]
  reviewHelpfulVotes      ReviewHelpfulVote[]
  reviewReports           ReviewReport[]
  supportAgentProfile     SupportAgent?
  requestedSupportTickets SupportTicket[]          @relation("SupportTicketRequester")
  assignedSupportTickets  SupportTicket[]          @relation("SupportTicketAssignee")
  supportMessages         SupportMessage[]         @relation("SupportMessageAuthor")
  claimMethods            ServerClaimMethod[]
  accountRoles            AccountRole[]

  @@unique([provider, providerUserId])
  @@index([email])
}

model GlobalRole {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(64)
  displayName String   @map("display_name") @db.VarChar(128)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  accountRoles    AccountRole[]
  rolePermissions RolePermission[]

  @@map("global_roles")
}

model AccountRole {
  id        String   @id @default(uuid())
  accountId String   @map("account_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  account Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  role    GlobalRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([accountId, roleId])
  @@index([roleId])
  @@map("account_roles")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique @db.VarChar(128)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at") @db.DateTime(3)

  role       GlobalRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditEvent {
  id             String   @id @default(uuid()) @db.Char(36)
  category       String   @db.VarChar(64)
  action         String   @db.VarChar(128)
  severity       String   @default("info") @db.VarChar(16)
  actorAccountId String?  @map("actor_account_id")
  actorProfileId BigInt?  @map("actor_profile_id")
  subjectType    String?  @map("subject_type") @db.VarChar(64)
  subjectId      String?  @map("subject_id") @db.VarChar(128)
  requestId      String?  @map("request_id") @db.VarChar(64)
  ipAddress      String?  @map("ip_address") @db.VarChar(64)
  userAgent      String?  @map("user_agent") @db.VarChar(512)
  metadata       Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@index([category, createdAt])
  @@index([action, createdAt])
  @@index([actorAccountId, createdAt])
  @@index([subjectType, subjectId, createdAt])
  @@map("audit_events")
}

model SiteSetting {
  key         String   @id @db.VarChar(128)
  value       Json
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("site_settings")
}

model AccountLink {
  id               String   @id @default(uuid())
  primaryAccountId String
  linkedAccountId  String
  createdAt        DateTime @default(now())

  primaryAccount Account @relation("AccountLinkPrimary", fields: [primaryAccountId], references: [id], onDelete: Cascade)
  linkedAccount  Account @relation("AccountLinkTarget", fields: [linkedAccountId], references: [id], onDelete: Cascade)

  @@unique([primaryAccountId, linkedAccountId])
  @@index([linkedAccountId])
}

model AccountLinkRequest {
  id               String            @id @default(uuid())
  primaryAccountId String
  targetAccountId  String
  verificationCode String
  status           AccountLinkStatus
  createdAt        DateTime          @default(now())
  confirmedAt      DateTime?

  primaryAccount Account @relation("LinkRequestPrimary", fields: [primaryAccountId], references: [id], onDelete: Cascade)
  targetAccount  Account @relation("LinkRequestTarget", fields: [targetAccountId], references: [id], onDelete: Cascade)

  @@index([primaryAccountId])
  @@index([targetAccountId])
}

model EmailVerification {
  token     String   @id
  accountId String
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
}

model PasswordReset {
  token     String   @id
  accountId String
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id           String   @id @default(uuid())
  accountId    String
  token        String   @unique
  issuedAt     DateTime
  expiresAt    DateTime
  tokenVersion Int
  isElevated   Boolean  @default(false)
  ipAddress    String?
  userAgent    String?
  lastActiveAt DateTime
  createdAt    DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
}

model OAuthState {
  state         String        @id
  provider      OAuthProvider
  redirectUri   String
  returnTo      String?
  createdAt     DateTime      @default(now())
  expiresAt     DateTime
  mode          OAuthMode     @default(login)
  linkAccountId String?

  linkAccount Account? @relation(fields: [linkAccountId], references: [id], onDelete: Cascade)
}

model OAuthCredential {
  id             String        @id @default(uuid())
  accountId      String
  provider       OAuthProvider
  providerUserId String
  accessToken    String        @db.Text
  refreshToken   String?       @db.Text
  tokenType      String?       @db.VarChar(32)
  scope          String?       @db.VarChar(512)
  expiresAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, provider, providerUserId])
  @@index([provider, providerUserId])
  @@index([expiresAt])
  @@map("oauth_credentials")
}

model MinecraftAuthorization {
  state        String   @id
  accountId    String
  redirectUri  String
  codeVerifier String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model MinecraftIdentity {
  accountId      String   @id
  uuid           String
  playerName     String?
  msOwned        Boolean
  lastVerifiedAt DateTime

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([uuid])
}

model Server {
  id                    String            @id @default(uuid())
  shortCode             String?           @unique @db.VarChar(12)
  ownerAccountId        String?
  wikiSpaceId           BigInt?           @db.UnsignedBigInt
  wikiPageId            BigInt?           @db.UnsignedBigInt
  wikiSlug              String?
  name                  String
  joinHost              String
  joinPort              Int
  edition               ServerEdition
  supportedVersions     Json
  tags                  Json
  shortDescription      String
  longDescription       String
  bannerUrl             String?
  websiteUrl            String?
  discordUrl            String?
  voteCooldownHours     Int               @default(24)
  verificationGrade     VerificationGrade @default(Unverified)
  verifiedAt            DateTime?
  votes24h              Int               @default(0)
  votesMonthly          Int?
  reviewsCount          Int               @default(0)
  voteRequiresOwnership Boolean           @default(false)
  playersOnline         Int?
  playersMax            Int?
  playersLastUpdatedAt  DateTime?
  isOnline              Boolean?
  latencyMs             Int?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  ownerAccount         Account?              @relation("ServerOwner", fields: [ownerAccountId], references: [id], onDelete: SetNull)
  stats                ServerStats?
  pingSamples          ServerPingSample[]
  votes                Vote[]
  voteDispatchAttempts VoteDispatchAttempt[]
  reviews              ServerReview[]
  claimMethods         ServerClaimMethod[]
  votifierTargets      VotifierTarget[]
  rankSnapshots        ServerRankSnapshot[]
  supportTickets       SupportTicket[]

  @@index([ownerAccountId])
  @@index([wikiSpaceId])
  @@index([wikiSlug])
  @@index([verificationGrade])
  @@index([votes24h])
  @@index([votesMonthly])
  @@index([reviewsCount])
}

model ServerStats {
  serverId             String    @id
  rankCurrent          Int       @default(1)
  rankDelta24h         Int       @default(0)
  rankBest             Int       @default(1)
  votesLast24h         Int       @default(0)
  votesLast7d          Int       @default(0)
  votesMonthToDate     Int       @default(0)
  votesTotal           Int       @default(0)
  playersOnline        Int       @default(0)
  playersMax           Int       @default(0)
  playersLastUpdatedAt DateTime?
  uptimePercent        Float     @default(0)
  sparkline            Json
  latencyMs            Int       @default(0)
  lastPingAt           DateTime?
  lastUpdatedAt        DateTime  @default(now()) @updatedAt

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)
}

model ServerPingSample {
  id         String   @id @default(uuid())
  serverId   String
  timestamp  DateTime
  online     Boolean
  players    Int?
  maxPlayers Int?
  latency    Int?
  motd       String?
  version    String?
  createdAt  DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, timestamp])
}

model Vote {
  id                 String   @id @default(uuid())
  serverId           String
  accountId          String?
  minecraftUuid      String?
  username           String
  usernameNormalized String
  ipAddress          String?
  votedAt            DateTime
  createdAt          DateTime @default(now())

  server           Server                @relation(fields: [serverId], references: [id], onDelete: Cascade)
  account          Account?              @relation(fields: [accountId], references: [id], onDelete: SetNull)
  dispatchAttempts VoteDispatchAttempt[]

  @@index([serverId, votedAt])
  @@index([serverId, accountId])
  @@index([serverId, minecraftUuid])
  @@index([serverId, usernameNormalized])
  @@index([serverId, ipAddress])
}

model VoteDispatchAttempt {
  id            String           @id @default(uuid()) @db.Char(36)
  voteId        String           @map("vote_id")
  serverId      String           @map("server_id")
  targetId      String?          @map("target_id")
  protocol      VotifierProtocol
  status        String           @default("queued") @db.VarChar(32)
  attempts      Int              @default(0)
  error         String?          @db.VarChar(512)
  lastAttemptAt DateTime?        @map("last_attempt_at") @db.DateTime(3)
  createdAt     DateTime         @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.DateTime(3)

  vote   Vote            @relation(fields: [voteId], references: [id], onDelete: Cascade)
  server Server          @relation(fields: [serverId], references: [id], onDelete: Cascade)
  target VotifierTarget? @relation(fields: [targetId], references: [id], onDelete: SetNull)

  @@index([voteId])
  @@index([serverId, createdAt])
  @@index([serverId, status, createdAt])
  @@index([targetId])
  @@map("vote_dispatch_attempts")
}

model ServerReview {
  id                  String           @id @default(uuid())
  serverId            String
  authorAccountId     String
  authorDisplayName   String
  rating              Int
  body                String
  tags                Json
  visibility          ReviewVisibility @default(public)
  isAnonymous         Boolean          @default(false)
  helpfulCount        Int              @default(0)
  reports             Int              @default(0)
  adminReplyBody      String?
  adminReplyAuthor    String?
  adminReplyCreatedAt DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  server        Server              @relation(fields: [serverId], references: [id], onDelete: Cascade)
  authorAccount Account             @relation(fields: [authorAccountId], references: [id], onDelete: Cascade)
  helpfulVotes  ReviewHelpfulVote[]
  reportsBy     ReviewReport[]

  @@index([serverId, createdAt])
  @@index([serverId, visibility])
}

model ReviewHelpfulVote {
  id           String   @id @default(uuid())
  reviewId     String
  accountId    String
  isHelpful    Boolean  @default(true)
  lastMarkedAt DateTime
  createdAt    DateTime @default(now())

  review  ServerReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([reviewId, accountId])
  @@index([accountId])
}

model ReviewReport {
  id        String   @id @default(uuid())
  reviewId  String
  accountId String
  createdAt DateTime @default(now())

  review  ServerReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([reviewId, accountId])
  @@index([accountId])
}

model ServerClaimMethod {
  id            String           @id @default(uuid())
  serverId      String
  accountId     String?
  method        ClaimMethod
  token         String
  issuedAt      DateTime
  status        ClaimMethodState @default(pending)
  verifiedAt    DateTime?
  lastCheckedAt DateTime?
  note          String?

  server  Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@unique([serverId, method])
  @@index([accountId])
}

model VotifierTarget {
  id        String           @id @default(uuid())
  serverId  String
  protocol  VotifierProtocol
  host      String
  port      Int
  token     String?
  publicKey String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  server           Server                @relation(fields: [serverId], references: [id], onDelete: Cascade)
  dispatchAttempts VoteDispatchAttempt[]

  @@index([serverId])
}

model ServerRankSnapshot {
  id               String   @id @default(uuid())
  serverId         String
  rank             Int
  votes24h         Int
  votesMonthToDate Int
  recordedAt       DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, recordedAt])
}

model SupportAgent {
  accountId   String   @id
  displayName String?
  createdAt   DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model SupportTicket {
  id                 String                @id @default(uuid())
  requesterAccountId String
  assigneeAccountId  String?
  serverId           String?
  subject            String
  status             SupportTicketStatus   @default(open)
  priority           SupportTicketPriority @default(normal)
  category           String?
  pageId             String?
  verifySessionId    String?
  pluginServerId     String?
  fileId             String?
  lastMessageAt      DateTime              @default(now())
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  requesterAccount Account          @relation("SupportTicketRequester", fields: [requesterAccountId], references: [id], onDelete: Cascade)
  assigneeAccount  Account?         @relation("SupportTicketAssignee", fields: [assigneeAccountId], references: [id], onDelete: SetNull)
  server           Server?          @relation(fields: [serverId], references: [id], onDelete: SetNull)
  messages         SupportMessage[]

  @@index([requesterAccountId, createdAt])
  @@index([assigneeAccountId, status])
  @@index([status, lastMessageAt])
  @@index([serverId])
  @@index([pageId])
  @@index([verifySessionId])
  @@index([pluginServerId])
  @@index([fileId])
}

model SupportMessage {
  id              String                   @id @default(uuid())
  ticketId        String
  authorAccountId String?
  authorRole      SupportMessageAuthorRole
  body            String
  isInternal      Boolean                  @default(false)
  createdAt       DateTime                 @default(now())

  ticket        SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  authorAccount Account?      @relation("SupportMessageAuthor", fields: [authorAccountId], references: [id], onDelete: SetNull)

  @@index([ticketId, createdAt])
  @@index([authorAccountId])
  @@index([isInternal])
}

model DiscordSubscription {
  guildId      String   @id
  channelId    String
  timezone     String
  roleRewardId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  nextDigestAt DateTime
}

model DiscordVerificationSession {
  id                 String    @id @default(uuid())
  status             String    @default("pending")
  guildId            String
  channelId          String
  requesterDiscordId String
  accountId          String?
  minecraftUuid      String?
  minecraftName      String?
  roleId             String?
  nicknameTemplate   String?
  verificationUrl    String?
  completionTokenHash String?   @map("completion_token_hash") @db.Char(64)
  eventLog           Json?
  syncAttempts       Int       @default(0)
  lastSyncStatus     String?
  createdAt          DateTime  @default(now())
  expiresAt          DateTime
  completedAt        DateTime?
  lastSyncAt         DateTime?

  @@index([guildId, requesterDiscordId])
  @@index([accountId])
  @@index([status, expiresAt])
}

model ServerPluginSyncEvent {
  id             String   @id @default(uuid())
  serverId       String?
  pluginServerId String?
  discordUserId  String?
  minecraftUuid  String
  playerName     String?
  action         String
  payload        Json?
  createdAt      DateTime @default(now())

  @@index([serverId, createdAt])
  @@index([pluginServerId, createdAt])
  @@index([minecraftUuid, createdAt])
  @@index([discordUserId, createdAt])
}

model PluginSyncReplayGuard {
  id        String   @id @default(uuid()) @db.Char(36)
  serverId  String   @map("server_id") @db.VarChar(32)
  nonce     String   @db.VarChar(128)
  expiresAt DateTime @map("expires_at") @db.DateTime(3)
  createdAt DateTime @default(now()) @map("created_at") @db.DateTime(3)

  @@unique([serverId, nonce])
  @@index([expiresAt])
  @@map("plugin_sync_replay_guards")
}

model PluginSyncCooldown {
  serverId   String   @id @map("server_id") @db.VarChar(32)
  lastSeenAt DateTime @map("last_seen_at") @db.DateTime(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@map("plugin_sync_cooldowns")
}

model PluginServer {
  id             String    @id @default(uuid()) @db.Char(36)
  serverId       String?   @map("minewiki_server_id")
  guildId        String    @map("guild_id") @db.VarChar(32)
  pluginServerId String    @unique @map("plugin_server_id") @db.VarChar(32)
  serverName     String    @map("server_name") @db.VarChar(100)
  host           String    @db.VarChar(255)
  port           Int
  endpointUrl    String?   @map("endpoint_url") @db.VarChar(512)
  serverSecret   String    @map("server_secret") @db.VarChar(128)
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.DateTime(3)
  lastSeenAt     DateTime? @map("last_seen_at") @db.DateTime(3)

  @@index([serverId])
  @@index([guildId])
  @@map("plugin_servers")
}

model UploadedFile {
  id             String   @id @default(uuid()) @db.Char(36)
  ownerAccountId String?  @map("owner_account_id") @db.Char(36)
  filename       String   @db.VarChar(255)
  originalName   String?  @map("original_name") @db.VarChar(255)
  mimeType       String   @map("mime_type") @db.VarChar(128)
  sizeBytes      Int      @map("size_bytes") @db.UnsignedInt
  width          Int?     @db.UnsignedInt
  height         Int?     @db.UnsignedInt
  sha256         String   @db.Char(64)
  storagePath    String   @map("storage_path") @db.VarChar(1024)
  publicPath     String   @map("public_path") @db.VarChar(1024)
  usageContext   String   @default("general") @map("usage_context") @db.VarChar(64)
  visibility     String   @default("public") @db.VarChar(32)
  linkedResourceType String? @map("linked_resource_type") @db.VarChar(64)
  linkedResourceId   String? @map("linked_resource_id") @db.VarChar(128)
  status         String   @default("active") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at") @db.DateTime(3)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.DateTime(3)

  @@index([ownerAccountId])
  @@index([usageContext])
  @@index([visibility])
  @@index([linkedResourceType, linkedResourceId])
  @@index([sha256])
  @@index([status])
  @@map("uploaded_files")
}

model LunaGuild {
  guildId            String   @id @map("guild_id") @db.VarChar(32)
  verifiedRoleId     String?  @map("verified_role_id") @db.VarChar(32)
  logChannelId       String?  @map("log_channel_id") @db.VarChar(32)
  nicknameFormat     String?  @map("nickname_format") @db.VarChar(128)
  botMessageTemplate String?  @map("bot_message_template") @db.VarChar(512)
  botMessagePayload  Json?    @map("bot_message_payload")
  verifyReplyPayload Json?    @map("verify_reply_payload")
  policyJson         Json?    @map("policy_json")
  createdAt          DateTime @map("created_at")
  updatedAt          DateTime @map("updated_at")

  @@map("guilds")
}

model LunaGuildChannelSetting {
  guildId            String   @map("guild_id") @db.VarChar(32)
  channelId          String   @map("channel_id") @db.VarChar(32)
  verifiedRoleId     String?  @map("verified_role_id") @db.VarChar(32)
  logChannelId       String?  @map("log_channel_id") @db.VarChar(32)
  nicknameFormat     String?  @map("nickname_format") @db.VarChar(128)
  botMessageTemplate String?  @map("bot_message_template") @db.VarChar(512)
  botMessagePayload  Json?    @map("bot_message_payload")
  verifyReplyPayload Json?    @map("verify_reply_payload")
  policyJson         Json?    @map("policy_json")
  createdAt          DateTime @map("created_at")
  updatedAt          DateTime @map("updated_at")

  @@id([guildId, channelId])
  @@index([guildId])
  @@map("guild_channel_settings")
}

model LunaGuildServer {
  id           BigInt    @id @default(autoincrement()) @db.UnsignedBigInt
  guildId      String    @map("guild_id") @db.VarChar(32)
  serverId     String    @unique @map("server_id") @db.VarChar(32)
  serverName   String    @map("server_name") @db.VarChar(100)
  serverHost   String    @map("server_host") @db.VarChar(255)
  serverPort   Int       @map("server_port")
  endpointUrl  String?   @map("endpoint_url") @db.VarChar(512)
