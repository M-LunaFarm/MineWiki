{
  "compilerOptions": {
    "target": "es2021",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": ["dom", "es2021"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@minewiki/config": ["packages/config/src"],
      "@minewiki/logger": ["packages/logger/src"],
      "@minewiki/schemas": ["packages/schemas/src"],
      "@minewiki/analytics": ["packages/analytics/src"],
      "@minewiki/auth": ["packages/auth/src"],
      "@minewiki/db": ["packages/db/src"],
      "@minewiki/minecraft": ["packages/minecraft/src"],
      "@minewiki/security": ["packages/security/src"],
      "@minewiki/wiki-core": ["packages/wiki-core/src"],
      "@minewiki/clients": ["packages/clients/src"],
      "@minewiki/ui": ["packages/ui/src"]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  }
}
