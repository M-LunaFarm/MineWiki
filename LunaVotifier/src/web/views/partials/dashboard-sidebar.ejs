<aside class="w-64 hidden lg:block sticky top-24 h-fit">
  <div class="space-y-6">
    <div>
      <h3 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-3 pl-4">일반 설정</h3>
      <div class="space-y-1">
        <a class="sidebar-item <%= sidebarActive === 'overview' ? 'active' : '' %>" href="/guilds/<%= guildId %><%= channelQuery %>">
          <span class="material-symbols-outlined">home</span>
          <span class="text-sm font-medium">개요</span>
        </a>
        <a class="sidebar-item <%= sidebarActive === 'settings' ? 'active' : '' %>" href="/guilds/<%= guildId %>/settings<%= channelQuery %>">
          <span class="material-symbols-outlined">settings</span>
          <span class="text-sm font-medium">설정</span>
        </a>
        <% if (canManageSettings) { %>
          <a class="sidebar-item <%= sidebarActive === 'messages' ? 'active' : '' %>" href="/guilds/<%= guildId %>/messages<%= channelQuery %>">
            <span class="material-symbols-outlined">chat</span>
            <span class="text-sm font-medium">메시지</span>
          </a>
          <a class="sidebar-item <%= sidebarActive === 'members' ? 'active' : '' %>" href="/guilds/<%= guildId %>/members<%= channelQuery %>">
            <span class="material-symbols-outlined">group</span>
            <span class="text-sm font-medium">멤버</span>
          </a>
        <% } %>
      </div>
    </div>
    <div>
      <h3 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-3 pl-4">마인크래프트 서버</h3>
      <div class="space-y-1">
        <% if (canManageSettings) { %>
          <a class="sidebar-item <%= sidebarActive === 'servers' ? 'active' : '' %>" href="/guilds/<%= guildId %>/servers<%= channelQuery %>">
            <span class="material-symbols-outlined">dns</span>
            <span class="text-sm font-medium">서버</span>
          </a>
        <% } %>
        <a class="sidebar-item <%= sidebarActive === 'logs' ? 'active' : '' %>" href="/guilds/<%= guildId %>/logs<%= channelQuery %>">
          <span class="material-symbols-outlined">analytics</span>
          <span class="text-sm font-medium">로그</span>
        </a>
      </div>
    </div>
    <% if (canManageSettings) { %>
      <div>
        <h3 class="text-xs font-bold text-white/40 uppercase tracking-widest mb-3 pl-4">액션/라우팅</h3>
        <div class="space-y-1">
          <a class="sidebar-item <%= sidebarActive === 'actions' ? 'active' : '' %>" href="/guilds/<%= guildId %>/actions<%= channelQuery %>">
            <span class="material-symbols-outlined">bolt</span>
            <span class="text-sm font-medium">액션</span>
          </a>
          <a class="sidebar-item <%= sidebarActive === 'routing' ? 'active' : '' %>" href="/guilds/<%= guildId %>/routing<%= channelQuery %>">
            <span class="material-symbols-outlined">alt_route</span>
            <span class="text-sm font-medium">라우팅</span>
          </a>
        </div>
      </div>
    <% } %>
  </div>
</aside>
