<%- include('../partials/top', { currentGuild: null }) %>

<section class="verify">
  <div class="login-card">
    <p class="eyebrow">동의 확인</p>
    <h1><%= consentTitle %></h1>
    <p><%= consentDescription %></p>
    <form class="form" method="post" action="/consent" id="consentForm" style="text-align: left; margin-top: 20px;">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
      <input type="hidden" name="flow" value="<%= flow %>" />
      <input type="hidden" name="redirect" value="<%= redirectPath %>" />
      <label class="checkbox" for="consentAgree">
        <input type="checkbox" name="agree" id="consentAgree" />
        <span>
          개인정보처리방침 및 이용약관에 동의합니다.
          <a href="/privacy" target="_blank" rel="noopener noreferrer">개인정보처리방침</a>
          /
          <a href="/terms" target="_blank" rel="noopener noreferrer">이용약관</a>
        </span>
      </label>
      <button class="btn btn-primary" type="submit" data-consent-submit disabled style="width: 100%; margin-top: 14px;">
        <%= consentButtonLabel %>
      </button>
      <p class="login-note">동의하지 않으면 계속할 수 없습니다.</p>
    </form>
  </div>
</section>

<script>
  (() => {
    const form = document.getElementById('consentForm');
    if (!form) return;
    const checkbox = form.querySelector('#consentAgree');
    const button = form.querySelector('[data-consent-submit]');
    const toggle = () => {
      const checked = checkbox && checkbox.checked;
      if (button) {
        button.disabled = !checked;
      }
    };
    if (checkbox) {
      checkbox.addEventListener('change', toggle);
    }
    toggle();
  })();
</script>

<%- include('../partials/bottom') %>
