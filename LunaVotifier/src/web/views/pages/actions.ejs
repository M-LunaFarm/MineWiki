<%
  const guildName = currentGuild?.name || 'Guild';
  const guildId = currentGuild?.id || '';
  const guildIconUrl = currentGuild?.icon ? `https://cdn.discordapp.com/icons/${guildId}/${currentGuild.icon}.png?size=160` : '';
  const safeSelectedChannelId = typeof selectedChannelId !== 'undefined' ? selectedChannelId : '';
  const channelQuery = safeSelectedChannelId ? `?channel_id=${safeSelectedChannelId}` : '';
  const navItems = [
    { key: 'overview', label: '개요', href: `/guilds/${guildId}${channelQuery}` },
    { key: 'settings', label: '설정', href: `/guilds/${guildId}/settings${channelQuery}` },
    ...(canManageSettings ? [
      { key: 'messages', label: '메시지', href: `/guilds/${guildId}/messages${channelQuery}` },
      { key: 'members', label: '멤버', href: `/guilds/${guildId}/members${channelQuery}` },
      { key: 'servers', label: '서버', href: `/guilds/${guildId}/servers${channelQuery}` },
      { key: 'actions', label: '액션', href: `/guilds/${guildId}/actions${channelQuery}` },
      { key: 'routing', label: '라우팅', href: `/guilds/${guildId}/routing${channelQuery}` }
    ] : []),
    { key: 'logs', label: '로그', href: `/guilds/${guildId}/logs${channelQuery}` }
  ];
%>
<%- include('../partials/top', { bodyClass: 'dashboard-page' }) %>

<section class="mx-auto flex w-full max-w-7xl flex-col gap-6">
  <div class="flex flex-col gap-5 rounded-lg border border-slate-200 bg-white/85 p-5 shadow-sm lg:flex-row lg:items-center lg:justify-between">
    <div class="flex min-w-0 items-center gap-4">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
        <% if (guildIconUrl) { %>
          <img alt="Server Icon" class="h-full w-full object-cover" src="<%= guildIconUrl %>" />
        <% } else { %>
          <span class="text-lg font-semibold text-slate-500"><%= guildName.slice(0, 2) %></span>
        <% } %>
      </div>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="m-0 truncate font-['Space_Grotesk'] text-2xl font-semibold text-slate-950"><%= guildName %></h1>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">액션</span>
        </div>
        <p class="mt-1 font-mono text-xs text-slate-500">ID: <%= guildId %></p>
      </div>
    </div>
    <a class="inline-flex items-center justify-center rounded-lg bg-slate-950 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-slate-800" href="/guilds/<%= guildId %>/actions/new<%= channelQuery %>">새 프로파일</a>
  </div>

  <nav class="flex gap-2 overflow-x-auto border-b border-slate-200 pb-3" aria-label="길드 관리 메뉴">
    <% navItems.forEach((item) => { %>
      <a class="whitespace-nowrap rounded-lg px-3 py-2 text-sm font-medium <%= item.key === 'actions' ? 'bg-slate-950 text-white' : 'text-slate-600 hover:bg-white hover:text-slate-950' %>" href="<%= item.href %>"><%= item.label %></a>
    <% }) %>
  </nav>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <form class="channel-form" method="get" action="<%= actionPath %>">
      <label>
        설정 적용 범위
        <select name="channel_id">
          <option value="">길드 기본값</option>
          <% if (allowAllChannels) { %>
            <option value="__all" <%= selectedChannelId === '__all' ? 'selected' : '' %>>모든 채널 보기</option>
          <% } %>
          <% channelOptions.forEach((channel) => { %>
            <option value="<%= channel.id %>" <%= selectedChannelId === channel.id ? 'selected' : '' %>>#<%= channel.name %></option>
          <% }) %>
        </select>
      </label>
      <button class="btn btn-ghost" type="submit">범위 적용</button>
    </form>
    <p class="channel-hint">채널별 설정이 없으면 길드 기본값을 사용합니다.</p>
  </section>

  <section class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
    <div class="section-header">
      <div>
        <h2>프로파일</h2>
        <p class="channel-hint"><%= profiles.length %>개</p>
      </div>
    </div>

    <div class="member-list">
      <% if (profiles.length === 0) { %>
        <p class="empty-state">아직 프로파일이 없습니다.</p>
      <% } %>
      <% profiles.forEach((profile) => { %>
        <article class="member-item">
          <div class="member-main">
            <div class="member-avatar" data-initial="<%= (profile.name || '액션').slice(0, 2) %>"></div>
            <div class="member-copy">
              <strong><%= profile.name %></strong>
              <p class="mono"><%= profile.trigger_event %></p>
              <% if (showChannelColumn) { %>
                <p class="channel-hint">채널: <%= profile.channel_id ? (channelNameMap[profile.channel_id] || profile.channel_id) : '기본값' %></p>
              <% } %>
              <p class="channel-hint">수정: <%= profile.updated_at_display || profile.updated_at || '-' %></p>
            </div>
          </div>
          <div class="member-actions">
            <span class="badge <%= profile.enabled ? 'badge-live' : 'badge-off' %>"><%= profile.enabled ? '활성' : '비활성' %></span>
            <a class="btn btn-ghost" href="/guilds/<%= guildId %>/actions/<%= profile.profile_id %><%= channelQuery %>">수정</a>
          </div>
        </article>
      <% }) %>
    </div>
  </section>
</section>

<%- include('../partials/bottom') %>
