<%
  const guildName = currentGuild?.name || 'Guild';
  const guildId = currentGuild?.id || '';
  const isEdit = Boolean(profile);
  const actionsValue = isEdit ? actionsText : JSON.stringify([{ type: 'console_command', command: 'whitelist add %player%' }], null, 2);
  const actionUrl = isEdit ? `/guilds/${guildId}/actions/${profile.profile_id}` : `/guilds/${guildId}/actions`;
  const channelQuery = selectedChannelId ? `?channel_id=${selectedChannelId}` : '';
%>
<%- include('../partials/top', { bodyClass: 'dashboard' }) %>

<div class="section-header">
  <div>
    <h1><%= isEdit ? '액션 프로파일 수정' : '새 액션 프로파일' %></h1>
    <p class="channel-hint"><%= guildName %>에서 이벤트별 동작을 저장합니다.</p>
  </div>
  <a class="btn btn-ghost" href="/guilds/<%= guildId %>/actions<%= channelQuery %>">목록으로</a>
</div>

<section class="card channel-select">
  <form class="channel-form" method="get" action="<%= actionPath %>">
    <label>
      설정 적용 범위
      <select name="channel_id">
        <option value="">길드 기본값</option>
        <% channelOptions.forEach((channel) => { %>
          <option value="<%= channel.id %>" <%= selectedChannelId === channel.id ? 'selected' : '' %>>#<%= channel.name %></option>
        <% }) %>
      </select>
    </label>
    <button class="btn btn-ghost" type="submit">범위 적용</button>
  </form>
  <% if (!botPresent) { %>
    <p class="channel-hint">봇이 길드에 없어 채널 목록을 불러올 수 없습니다.</p>
    <% if (botInviteUrl) { %><a class="btn btn-primary" href="<%= botInviteUrl %>" target="_blank" rel="noopener noreferrer">봇 초대</a><% } %>
  <% } %>
</section>

<form id="actionProfileForm" class="form" method="post" action="<%= actionUrl %>">
  <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
  <input type="hidden" name="channel_id" value="<%= selectedChannelId %>" />

  <div class="grid two">
    <section class="card">
      <h2>기본 정보</h2>
      <label>
        프로파일 이름
        <input name="name" placeholder="인증 성공 보상 지급" type="text" value="<%= profile ? profile.name : '' %>" required />
      </label>
      <label>
        트리거 이벤트
        <select name="trigger_event">
          <% eventTypes.forEach((eventType) => { %>
            <option value="<%= eventType.key %>" <%= profile && profile.trigger_event === eventType.key ? 'selected' : '' %>><%= eventType.label %></option>
          <% }) %>
        </select>
      </label>
      <label class="checkbox">
        <input <%= !profile || profile.enabled ? 'checked' : '' %> name="enabled" type="checkbox" value="1" />
        활성화
      </label>
    </section>

    <section class="card">
      <h2>액션 빌더</h2>
      <div class="grid three">
        <label>
          액션 타입
          <select id="builderType">
            <option value="console_command">콘솔 명령</option>
            <option value="player_command">플레이어 명령</option>
            <option value="player_message">플레이어 메시지</option>
            <option value="broadcast">서버 전체 메시지</option>
            <option value="http_request">웹훅/HTTP 요청</option>
          </select>
        </label>
        <label>
          내용
          <input id="builderValue" placeholder="whitelist add %player%" type="text" />
        </label>
        <label>
          옵션
          <input id="builderOption" placeholder="플레이어/URL 등" type="text" />
        </label>
      </div>
      <div class="action-stack">
        <button class="btn btn-secondary" id="builderAdd" type="button">액션 추가</button>
        <button class="btn btn-ghost" type="button" data-template="console">콘솔 템플릿</button>
        <button class="btn btn-ghost" type="button" data-template="webhook">웹훅 템플릿</button>
        <button class="btn btn-ghost" type="button" data-action="format">JSON 정리</button>
      </div>
      <p class="channel-hint" id="builderMessage">액션을 추가하면 JSON 배열에 누적됩니다.</p>
    </section>
  </div>

  <section class="card">
    <h2>액션 JSON/명령어</h2>
    <textarea class="mono" id="actionsJson" name="actions_json" rows="14" placeholder='[{ "type": "console_command", "command": "whitelist add %player%" }]'><%= actionsValue %></textarea>
    <div class="highlight">
      <p class="channel-hint">치환값: <span class="mono">%player%</span>, <span class="mono">%uuid%</span>, <span class="mono">%discord_id%</span>, <span class="mono">%guild_id%</span>, <span class="mono">%channel_id%</span>, <span class="mono">%event_type%</span></p>
      <p class="channel-hint">지원 타입: console_command, player_command, player_message, broadcast, http_request</p>
    </div>
    <div class="action-stack">
      <a class="btn btn-ghost" href="/guilds/<%= guildId %>/actions<%= channelQuery %>">취소</a>
      <button class="btn btn-primary" type="submit"><%= isEdit ? '저장' : '생성' %></button>
    </div>
  </section>
</form>

<% if (profile) { %>
  <section class="card danger">
    <h2>프로파일 삭제</h2>
    <p class="channel-hint">삭제 후 되돌릴 수 없습니다.</p>
    <form method="post" action="/guilds/<%= guildId %>/actions/<%= profile.profile_id %>/delete">
      <input type="hidden" name="csrf_token" value="<%= csrfToken %>" />
      <input type="hidden" name="channel_id" value="<%= selectedChannelId %>" />
      <button class="btn btn-danger" type="submit">삭제</button>
    </form>
  </section>
<% } %>

<script>
  (() => {
    const textarea = document.getElementById('actionsJson');
    const builderType = document.getElementById('builderType');
    const builderValue = document.getElementById('builderValue');
    const builderOption = document.getElementById('builderOption');
    const builderAdd = document.getElementById('builderAdd');
    const builderMessage = document.getElementById('builderMessage');
    if (!textarea) return;
    const templates = {
      console: [{ type: 'console_command', command: 'whitelist add %player%' }],
      webhook: [{ type: 'http_request', method: 'POST', url: 'https://example.com/webhook', body: { player: '%player%', uuid: '%uuid%' } }]
    };
    const setMessage = (text) => { if (builderMessage) builderMessage.textContent = text; };
    document.querySelectorAll('[data-template]').forEach((button) => {
      button.addEventListener('click', () => {
        const key = button.getAttribute('data-template');
        if (templates[key]) textarea.value = JSON.stringify(templates[key], null, 2);
        setMessage('템플릿을 적용했습니다.');
      });
    });
    const formatButton = document.querySelector('[data-action="format"]');
    if (formatButton) {
      formatButton.addEventListener('click', () => {
        try {
          textarea.value = JSON.stringify(textarea.value.trim() ? JSON.parse(textarea.value) : [], null, 2);
          setMessage('JSON을 정리했습니다.');
        } catch (err) {
          setMessage('JSON 형식을 확인하세요.');
        }
      });
    }
    if (builderAdd) {
      builderAdd.addEventListener('click', () => {
        const type = builderType ? builderType.value : 'console_command';
        const value = builderValue ? builderValue.value.trim() : '';
        const option = builderOption ? builderOption.value.trim() : '';
        if (!value) return setMessage('내용을 입력해 주세요.');
        let actions;
        try {
          actions = textarea.value.trim() ? JSON.parse(textarea.value) : [];
          if (!Array.isArray(actions)) throw new Error('not-array');
        } catch (err) {
          return setMessage('JSON 배열 상태에서 추가할 수 있습니다.');
        }
        if (type === 'http_request') {
          const [method, url] = option.split(' ').map((part) => part.trim()).filter(Boolean);
          actions.push({ type, method: method || 'POST', url: url || value, body: { player: '%player%' } });
        } else if (type === 'player_command') {
          actions.push({ type, command: value, player: option || '%player%' });
        } else if (type === 'player_message') {
          actions.push({ type, message: value, player: option || '%player%' });
        } else if (type === 'broadcast') {
          actions.push({ type, message: value });
        } else {
          actions.push({ type: 'console_command', command: value });
        }
        textarea.value = JSON.stringify(actions, null, 2);
        builderValue.value = '';
        builderOption.value = '';
        setMessage('액션이 추가되었습니다.');
      });
    }
  })();
</script>

<%- include('../partials/bottom') %>
