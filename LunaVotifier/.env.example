# 내부 API 요청에 사용하는 키 (봇/웹 내부 통신용)
INTERNAL_API_KEY=change-me

# 봇 이벤트 웹훅 서명에 사용하는 공유 시크릿
BOT_SHARED_SECRET=change-me

# 웹 세션 쿠키 서명용 시크릿 (랜덤 문자열 권장)
SESSION_SECRET=change-me

# 웹 서버 포트
WEB_PORT=3000

# 외부 공개 주소 (검증 링크 생성에 사용)
PUBLIC_BASE_URL=http://localhost:3000

# DB 접속 정보
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lunaf_verify

# 관리자 API 접근용 키 (대시보드 아닌 API 호출 시)
ADMIN_API_KEY=change-me

# Microsoft 로그인 Mock 모드 사용 여부 (1=사용)
ALLOW_MOCK_MS_LOGIN=1

# 인증 세션 만료 시간(분)
VERIFY_SESSION_TTL_MINUTES=10

# 서버 푸시 요청 타임아웃(ms)
PUSH_TIMEOUT_MS=5000

# 푸시 재시도 최대 횟수
PUSH_MAX_RETRIES=5

# 재시도 기본 대기 시간(초)
PUSH_RETRY_BASE_SECONDS=30

# 워커가 한번에 처리할 전송 건수
PUSH_BATCH_LIMIT=25

# 웹이 봇으로 이벤트를 보내는 웹훅 URL
BOT_WEBHOOK_URL=http://localhost:3100/bot/events

# Discord OAuth (대시보드 로그인)
DISCORD_OAUTH_CLIENT_ID=change-me
DISCORD_OAUTH_CLIENT_SECRET=change-me
DISCORD_OAUTH_REDIRECT_URI=http://localhost:3000/auth/discord/callback
DISCORD_OAUTH_SCOPES=identify guilds

# Microsoft OAuth (Minecraft 소유권 검증)
MS_CLIENT_ID=change-me
MS_CLIENT_SECRET=change-me
MS_REDIRECT_URI=http://localhost:3000/auth/microsoft/callback
MS_TENANT=common

# 봇 서버 포트
BOT_PORT=3100

# 봇에서 호출하는 웹 API 기본 주소
WEB_API_BASE_URL=http://localhost:3000

# Discord 봇 토큰
DISCORD_TOKEN=change-me

# Discord 애플리케이션 Client ID
DISCORD_CLIENT_ID=change-me

# 봇 초대 기본 권한(정수 비트셋)
BOT_INVITE_PERMISSIONS=402721792

# 슬래시 커맨드를 특정 길드에만 등록할 때 사용 (비우면 전역 등록)
DISCORD_GUILD_ID=
