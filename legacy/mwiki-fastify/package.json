{
  "name": "minewiki-engine",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "migrate": "tsx src/migrate.ts",
    "seed": "tsx src/seed.ts",
    "cleanup:placeholders": "tsx scripts/cleanup-placeholder-pages.ts",
    "audit:routes": "tsx scripts/audit-public-routes.ts",
    "audit:mobile": "tsx scripts/audit-mobile-render.ts",
    "audit:desktop": "tsx scripts/audit-desktop-render.ts",
    "audit:affordances": "tsx scripts/audit-live-affordances.ts",
    "audit:route-coverage": "tsx scripts/audit-route-coverage.ts",
    "check": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.0",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.17",
    "bcryptjs": "^3.0.2",
    "dotenv": "^17.2.3",
    "fastify": "^5.6.2",
    "fastify-plugin": "^5.1.0",
    "googleapis": "^172.0.0",
    "mysql2": "^3.15.3",
    "sanitize-html": "^2.17.0",
    "tsx": "^4.20.6",
    "undici": "^7.16.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "@types/sanitize-html": "^2.16.0",
    "playwright-core": "^1.60.0",
    "typescript": "^5.9.3"
  }
}
