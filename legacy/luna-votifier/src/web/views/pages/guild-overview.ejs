<%
  const guildName = currentGuild?.name || 'Guild';
  const guildId = currentGuild?.id || '';
  const guildIconUrl = currentGuild?.icon ? `https://cdn.discordapp.com/icons/${guildId}/${currentGuild.icon}.png?size=160` : '';
  const overviewEvents = Array.isArray(recentEvents) ? recentEvents : [];
  const verifiedCount = stats?.verified ?? 0;
  const totalEvents = stats?.events ?? 0;
  const failedCount = stats?.failed ?? 0;
  const failureRate = totalEvents ? ((failedCount / totalEvents) * 100).toFixed(1) : '0.0';
  const navItems = [
    { key: 'overview', label: '개요', href: `/guilds/${guildId}${channelQuery}` },
    { key: 'settings', label: '설정', href: `/guilds/${guildId}/settings${channelQuery}` },
    ...(canManageSettings ? [
      { key: 'messages', label: '메시지', href: `/guilds/${guildId}/messages${channelQuery}` },
      { key: 'members', label: '멤버', href: `/guilds/${guildId}/members${channelQuery}` },
      { key: 'servers', label: '서버', href: `/guilds/${guildId}/servers${channelQuery}` },
      { key: 'actions', label: '액션', href: `/guilds/${guildId}/actions${channelQuery}` },
      { key: 'routing', label: '라우팅', href: `/guilds/${guildId}/routing${channelQuery}` }
    ] : []),
    { key: 'logs', label: '로그', href: `/guilds/${guildId}/logs${channelQuery}` }
  ];
%>
<%- include('../partials/top', { bodyClass: 'dashboard-page' }) %>

<style>
  .dashboard-page .page { max-width: 1280px; margin: 0 auto; width: 100%; }
  .bg-white\/85 { background: rgba(255,255,255,.85); }
  .bg-slate-50 { background: #f8fafc; }
  .bg-slate-100 { background: #f1f5f9; }
  .bg-slate-950 { background: #020617; }
  .bg-blue-50 { background: #eff6ff; }
  .bg-amber-50 { background: #fffbeb; }
  .bg-emerald-50 { background: #ecfdf5; }
  .bg-rose-50 { background: #fff1f2; }
  .border-slate-100 { border-color: #f1f5f9; }
  .border-slate-200 { border-color: #e2e8f0; }
  .border-slate-300 { border-color: #cbd5e1; }
  .text-slate-950 { color: #020617; }
  .text-slate-800 { color: #1e293b; }
  .text-slate-700 { color: #334155; }
  .text-slate-600 { color: #475569; }
  .text-slate-500 { color: #64748b; }
  .text-teal-600 { color: #0d9488; }
  .text-blue-600 { color: #2563eb; }
  .text-blue-700 { color: #1d4ed8; }
  .text-amber-700 { color: #b45309; }
  .text-emerald-700 { color: #047857; }
  .text-rose-600 { color: #e11d48; }
  .text-rose-700 { color: #be123c; }
  .ring-blue-100 { --tw-ring-color: #dbeafe; }
  .ring-amber-100 { --tw-ring-color: #fef3c7; }
  .ring-emerald-100 { --tw-ring-color: #d1fae5; }
  .ring-rose-100 { --tw-ring-color: #ffe4e6; }
  .divide-slate-100 > :not([hidden]) ~ :not([hidden]) { border-color: #f1f5f9; }
  .shadow-sm { box-shadow: 0 1px 2px rgba(15,23,42,.08); }
  @media (hover:hover) {
    .hover\:bg-white:hover { background: #fff; }
    .hover\:bg-slate-50:hover { background: #f8fafc; }
    .hover\:text-slate-950:hover { color: #020617; }
  }
</style>

<section class="mx-auto flex w-full max-w-7xl flex-col gap-6">
  <div class="flex flex-col gap-5 rounded-lg border border-slate-200 bg-white/85 p-5 shadow-sm lg:flex-row lg:items-center lg:justify-between">
    <div class="flex min-w-0 items-center gap-4">
      <div class="flex h-16 w-16 shrink-0 items-center justify-center overflow-hidden rounded-lg border border-slate-200 bg-slate-100">
        <% if (guildIconUrl) { %>
          <img alt="Server Icon" class="h-full w-full object-cover" src="<%= guildIconUrl %>" />
        <% } else { %>
          <span class="text-lg font-semibold text-slate-500"><%= guildName.slice(0, 2) %></span>
        <% } %>
      </div>
      <div class="min-w-0">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="m-0 truncate font-['Space_Grotesk'] text-2xl font-semibold text-slate-950"><%= guildName %></h1>
          <span class="rounded-full border border-slate-200 bg-slate-50 px-2.5 py-1 text-xs font-medium text-slate-600">개요</span>
        </div>
        <p class="mt-1 font-mono text-xs text-slate-500">ID: <%= guildId %></p>
      </div>
    </div>
    <a class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm hover:bg-slate-50" href="/guilds/<%= guildId %>/logs<%= channelQuery %>">
      로그 보기
    </a>
  </div>

  <nav class="flex gap-2 overflow-x-auto border-b border-slate-200 pb-3">
    <% navItems.forEach((item) => { %>
      <a class="whitespace-nowrap rounded-lg px-3 py-2 text-sm font-medium <%= item.key === 'overview' ? 'bg-slate-950 text-white' : 'text-slate-600 hover:bg-white hover:text-slate-950' %>" href="<%= item.href %>"><%= item.label %></a>
    <% }) %>
  </nav>

  <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <p class="m-0 text-sm font-medium text-slate-500">인증 완료</p>
        <span class="material-symbols-outlined text-xl text-teal-600">verified_user</span>
      </div>
      <p class="mt-4 text-3xl font-semibold tabular-nums text-slate-950"><%= verifiedCount %></p>
      <p class="mt-1 text-xs text-slate-500">인증 완료된 계정 수</p>
    </article>
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <p class="m-0 text-sm font-medium text-slate-500">전체 이벤트</p>
        <span class="material-symbols-outlined text-xl text-blue-600">event_note</span>
      </div>
      <p class="mt-4 text-3xl font-semibold tabular-nums text-slate-950"><%= totalEvents %></p>
      <p class="mt-1 text-xs text-slate-500">기록된 이벤트 수</p>
    </article>
    <article class="rounded-lg border border-slate-200 bg-white p-5 shadow-sm">
      <div class="flex items-center justify-between gap-3">
        <p class="m-0 text-sm font-medium text-slate-500">전송 실패</p>
        <span class="material-symbols-outlined text-xl text-rose-600">sms_failed</span>
      </div>
      <div class="mt-4 flex items-end gap-2">
        <p class="m-0 text-3xl font-semibold tabular-nums text-slate-950"><%= failedCount %></p>
        <p class="mb-1 text-xs font-medium text-slate-500"><%= failureRate %>%</p>
      </div>
      <p class="mt-1 text-xs text-slate-500">실패한 푸시 이벤트 수</p>
    </article>
  </div>

  <section class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
    <div class="flex flex-col gap-2 border-b border-slate-200 px-5 py-4 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="m-0 text-base font-semibold text-slate-950">최근 이벤트</h2>
        <p class="m-0 mt-1 text-sm text-slate-500">최근 5개 이벤트입니다.</p>
      </div>
      <span class="text-xs font-medium text-slate-500">총 <%= overviewEvents.length %>건 표시</span>
    </div>

    <div class="hidden grid-cols-12 gap-4 border-b border-slate-100 bg-slate-50 px-5 py-3 text-xs font-semibold uppercase tracking-wide text-slate-500 md:grid">
      <div class="col-span-4">이벤트 유형</div>
      <div class="col-span-3">디스코드 ID</div>
      <div class="col-span-3">IGN</div>
      <div class="col-span-2 text-right">시각</div>
    </div>

    <div class="divide-y divide-slate-100">
      <% if (overviewEvents.length === 0) { %>
        <div class="px-5 py-8 text-sm text-slate-500">아직 이벤트가 없습니다.</div>
      <% } %>
      <% overviewEvents.forEach((event) => { %>
        <%
          const type = event.event_type || 'unknown';
          let chipClass = 'bg-blue-50 text-blue-700 ring-blue-100';
          if (type.includes('revoked')) {
            chipClass = 'bg-amber-50 text-amber-700 ring-amber-100';
          } else if (type.includes('completed')) {
            chipClass = 'bg-emerald-50 text-emerald-700 ring-emerald-100';
          } else if (type.includes('failed')) {
            chipClass = 'bg-rose-50 text-rose-700 ring-rose-100';
          }
        %>
        <div class="grid grid-cols-1 gap-3 px-5 py-4 text-sm text-slate-700 md:grid-cols-12 md:items-center md:gap-4">
          <div class="md:col-span-4">
            <span class="inline-flex max-w-full items-center rounded-full px-2.5 py-1 text-xs font-semibold ring-1 <%= chipClass %>"><%= type %></span>
          </div>
          <div class="min-w-0 font-mono text-xs text-slate-500 md:col-span-3"><%= event.discord_user_id %></div>
          <div class="min-w-0 font-medium text-slate-800 md:col-span-3"><%= event.mc_ign %></div>
          <div class="text-xs text-slate-500 md:col-span-2 md:text-right"><%= event.occurred_at_display %></div>
        </div>
      <% }) %>
    </div>
  </section>
</section>

<%- include('../partials/bottom') %>
