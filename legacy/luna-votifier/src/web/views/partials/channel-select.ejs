<section class="channel-select card">
  <form class="channel-form" method="get" action="<%= actionPath %>">
    <label>
      Channel Scope
      <select name="channel_id">
        <option value="">Guild Default (fallback when no channel override)</option>
        <% if (allowAllChannels) { %>
          <option value="__all" <%= selectedChannelId === '__all' ? 'selected' : '' %>>All Channels (view list only)</option>
        <% } %>
        <% channelOptions.forEach((channel) => { %>
          <option value="<%= channel.id %>" <%= selectedChannelId === channel.id ? 'selected' : '' %>><%= channel.name %></option>
        <% }) %>
      </select>
    </label>
    <button class="btn btn-ghost" type="submit">Apply</button>
  </form>
  <% if (!botPresent) { %>
    <div class="channel-hint">
      <p>봇이 길드에 초대되지 않아 채널 목록을 불러올 수 없습니다.</p>
      <% if (botInviteUrl) { %>
        <a class="btn btn-secondary" href="<%= botInviteUrl %>" target="_blank" rel="noopener noreferrer">Invite Bot</a>
      <% } %>
    </div>
  <% } %>
</section>
