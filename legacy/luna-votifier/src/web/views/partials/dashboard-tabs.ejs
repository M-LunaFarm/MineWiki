<div class="flex flex-wrap gap-4 border-b border-white/5 pb-6 mb-10">
  <a class="tab-pill <%= tabActive === 'overview' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %><%= channelQuery %>">개요</a>
  <a class="tab-pill <%= tabActive === 'settings' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/settings<%= channelQuery %>">설정</a>
  <% if (canManageSettings) { %>
    <a class="tab-pill <%= tabActive === 'messages' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/messages<%= channelQuery %>">메시지</a>
    <a class="tab-pill <%= tabActive === 'members' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/members<%= channelQuery %>">멤버</a>
    <a class="tab-pill <%= tabActive === 'servers' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/servers<%= channelQuery %>">서버</a>
    <a class="tab-pill <%= tabActive === 'actions' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/actions<%= channelQuery %>">액션</a>
    <a class="tab-pill <%= tabActive === 'routing' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/routing<%= channelQuery %>">라우팅</a>
  <% } %>
  <a class="tab-pill <%= tabActive === 'logs' ? 'active' : 'inactive' %>" href="/guilds/<%= guildId %>/logs<%= channelQuery %>">로그</a>
</div>
