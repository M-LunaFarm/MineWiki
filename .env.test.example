NODE_ENV=test

# Unit tests never connect to a database. Use `pnpm test:integration` to opt in;
# the guarded runner accepts only database names containing a standalone `test` segment.
# Set these values for local integration tests or CI services.
DATABASE_URL=mysql://minewiki:minewiki@127.0.0.1:3306/minewiki_test
REDIS_URL=redis://127.0.0.1:6379

NEXT_PUBLIC_SITE_URL=http://127.0.0.1:4311
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3000
INTERNAL_API_BASE_URL=http://127.0.0.1:3000
WEBAUTHN_ORIGIN=http://localhost:4311
WEBAUTHN_RP_ID=localhost
API_HOST=127.0.0.1
API_PORT=3000
VERIFY_PUBLIC_BASE_URL=http://127.0.0.1:4311

ACCOUNT_LINKING_ENABLED=true
APP_ENCRYPTION_KEY=test-encryption-key
INTERNAL_BOT_API_TOKEN=test-internal-bot-token
PLUGIN_SYNC_TOKEN=test-plugin-sync-token

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=test-discord-client-id
DISCORD_CLIENT_SECRET=test-discord-client-secret
DISCORD_REDIRECT_URI=http://127.0.0.1:4311/auth/callback/discord

MICROSOFT_CLIENT_ID=test-microsoft-client-id
MICROSOFT_CLIENT_SECRET=test-microsoft-client-secret
MICROSOFT_REDIRECT_URI=http://127.0.0.1:4311/minecraft/callback

NAVER_CLIENT_ID=test-naver-client-id
NAVER_CLIENT_SECRET=test-naver-client-secret
NAVER_REDIRECT_URI=http://127.0.0.1:4311/auth/callback/naver

TURNSTILE_SECRET_KEY=
HCAPTCHA_SECRET_KEY=

UPLOAD_STORAGE_ROOT=/tmp/minewiki-test-uploads
STORAGE_PUBLIC_BASE_URL=http://127.0.0.1:4311/uploads

SMTP_HOST=
SMTP_PORT=587
SMTP_FROM="MineWiki Test <test@example.invalid>"
