{
  "name": "@minewiki/api",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/apps/api/src/main.js",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "tsx --require ./src/test/database-test-environment.cjs --test \"src/**/*.test.ts\"",
    "test:runtime": "node --test --test-force-exit \"runtime-tests/*.test.cjs\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@minewiki/analytics": "workspace:*",
    "@minewiki/auth": "workspace:*",
    "@minewiki/config": "workspace:*",
    "@minewiki/logger": "workspace:*",
    "@minewiki/minecraft": "workspace:*",
    "@minewiki/schemas": "workspace:*",
    "@minewiki/security": "workspace:*",
    "@minewiki/wiki-core": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/platform-fastify": "^11.1.28",
    "@nestjs/throttler": "^6.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@opentelemetry/api": "^1.9.0",
    "@prisma/client": "^6.19.2",
    "@sentry/node": "^8.29.0",
    "@simplewebauthn/server": "^13.3.1",
    "bullmq": "^5.6.1",
    "cookie": "^0.6.0",
    "fastify": "^5.10.0",
    "file-type": "^18.7.0",
    "ioredis": "5.10.1",
    "minecraft-server-util": "^5.4.4",
    "node-diff3": "3.1.2",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@types/node": "^20.11.19",
    "prisma": "^6.17.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.0",
    "typescript": "^5.4.2"
  }
}
